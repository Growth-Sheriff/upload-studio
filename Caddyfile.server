    header X-Content-Type-Options nosniff
    header X-XSS-Protection "1; mode=block"
    header Referrer-Policy strict-origin-when-cross-origin
}

# ============================================
# Upload Studio - Multi-Tenant Wildcard
# ============================================
# Wildcard routing: *.uploadstudio.app.techifyboost.com
# Each subdomain maps to a tenant Docker container port.
# ============================================

# --- Upload Proxy for BunnyCDN ---
upload.uploadstudio.app.techifyboost.com {
    reverse_proxy https://storage.bunnycdn.com {
        header_up Host {upstream_hostport}
    }
    request_body {
        max_size 1500MB
    }
}

