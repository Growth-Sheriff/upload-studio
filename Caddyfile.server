# Twenty CRM - Sales Platform
sales.techifyboost.com {
    reverse_proxy multiservice-twenty-server:3000
    encode gzip

    # Allow iframe embedding from admin panels
    header -X-Frame-Options
    header Content-Security-Policy  frame-ancestors self https://app.dtfbank.com https://app.fastdtftransfer.com https://app.dtfprintdepot.com https://app.eagledtfprint.com https://*.techifyboost.com
}

# Twenty CRM proxy for DTFBank (same-site cookie fix for iframe)
crm.dtfbank.com {
    reverse_proxy multiservice-twenty-server:3000
    encode gzip

    # Allow iframe embedding from DTFBank admin
    header -X-Frame-Options
    header Content-Security-Policy "frame-ancestors self https://app.dtfbank.com https://*.dtfbank.com"
}

# === GSB Engine - DTF Print Depot (h1s00r-21.myshopify.com) ===
dtf-print-depot.gangsheetstudio.techifyboost.com {
    encode zstd gzip
    header -X-Frame-Options
    header Content-Security-Policy "frame-ancestors 'self' https://admin.shopify.com https://*.myshopify.com;"
    header X-Content-Type-Options nosniff

    route {
        reverse_proxy gangsheetbuilder-app-dtf-print-depot:4000
    }
}

# === Customer Protect - Shopify User Management App ===
customer-protect.techifyboost.com {
