{% comment %}
  Upload Studio - Builder Modal Block
  =====================================
  Mode: builder (Gang-sheet / DTF-by-size builder)
  Location: Product page

  This block renders an "Open Builder" button that launches the
  full-featured Builder Modal with:
  - Multi-file upload (drag & drop)
  - Canvas tab (marching ants, inch labels, reference squares)
  - FitCheck tab (6 mockups, 14-color picker)
  - Dimension controls with aspect-ratio lock
  - Add to Cart with line item properties

  USAGE: Add this block to your product page in Theme Editor
  (alongside or instead of the DTF Transfer block)

  Version: 1.0.0
{% endcomment %}

{% comment %}
  Load Global State Manager (FAZ 4)
  MUST load before other components
{% endcomment %}
<script src="{{ 'ul-state.js' | asset_url }}" defer></script>

{% comment %}
  Customer Data for Upload Attribution
{% endcomment %}
<script>
  window.ULCustomer = window.ULCustomer || {
    id: {{ customer.id | default: 'null' }},
    email: {{ customer.email | json | default: 'null' }}
  };
</script>

{% comment %}
  Visitor Tracking Fallback
{% endcomment %}
<script
  src="{{ 'ul-visitor.js' | asset_url }}"
  defer
  data-shop-domain="{{ shop.permanent_domain }}"
></script>

{% comment %}
  Builder CSS
{% endcomment %}
{{ 'ul-builder.css' | asset_url | stylesheet_tag }}

{% comment %}
  Builder JS Modules (order matters: upload → canvas → fitcheck → modal)
{% endcomment %}
<script src="{{ 'ul-builder-upload.js' | asset_url }}" defer></script>
<script src="{{ 'ul-builder-canvas.js' | asset_url }}" defer></script>
<script src="{{ 'ul-builder-fitcheck.js' | asset_url }}" defer></script>
<script src="{{ 'ul-builder-modal.js' | asset_url }}" defer></script>

{% comment %}
  Open Builder Button
{% endcomment %}
<div
  class="ul-builder-trigger"
  id="ul-builder-trigger-{{ product.id }}"
  data-product-id="{{ product.id }}"
  data-shop-domain="{{ shop.permanent_domain }}"
  data-api-base="/apps/customizer"
  data-currency="{{ cart.currency.iso_code }}"
  data-money-format="{{ shop.money_format | strip_html | escape }}"
>
  {% if block.settings.show_header %}
    <p class="ul-builder-header" style="
      font-size: 16px;
      font-weight: 600;
      margin-bottom: 8px;
      color: inherit;
    ">
      {{ block.settings.header_text }}
    </p>
  {% endif %}

  <button
    type="button"
    class="ul-builder-open-btn"
    id="ul-builder-open-{{ product.id }}"
    style="
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 14px 28px;
      background: {{ block.settings.btn_bg_color }};
      color: {{ block.settings.btn_text_color }};
      border: none;
      border-radius: {{ block.settings.btn_radius }}px;
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
      transition: opacity 200ms ease;
      font-family: inherit;
      width: {{ block.settings.btn_full_width | default: false | ternary: '100%', 'auto' }};
      justify-content: center;
    "
  >
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
      <polyline points="17 8 12 3 7 8"/>
      <line x1="12" y1="3" x2="12" y2="15"/>
    </svg>
    {{ block.settings.btn_text }}
  </button>

  {% if block.settings.show_subtext %}
    <p class="ul-builder-subtext" style="
      font-size: 12px;
      color: #6b7280;
      margin-top: 6px;
    ">
      {{ block.settings.subtext }}
    </p>
  {% endif %}
</div>

{% comment %}
  Initialization Script
{% endcomment %}
<script>
  (function () {
    function initBuilder() {
      var trigger = document.getElementById('ul-builder-trigger-{{ product.id }}');
      if (!trigger) return;

      var productId = trigger.dataset.productId;
      var shopDomain = trigger.dataset.shopDomain;
      var apiBase = trigger.dataset.apiBase;
      var currency = trigger.dataset.currency || 'USD';
      var moneyFormat = trigger.dataset.moneyFormat || '${% raw %}{{amount}}{% endraw %}';

      // Initialize Modal
      if (window.ULBuilderModal) {
        window.ULBuilderModal.init({
          productId: productId,
          shopDomain: shopDomain,
          apiBase: apiBase,
          currency: currency,
          moneyFormat: moneyFormat,
        });
      }

      // Bind open button
      var btn = document.getElementById('ul-builder-open-{{ product.id }}');
      if (btn) {
        btn.addEventListener('click', function () {
          if (window.ULBuilderModal) {
            window.ULBuilderModal.open();
          }
        });
      }

      // Analytics tracking
      if (window.ULAnalytics) {
        window.ULAnalytics.track('builder_block_loaded', {
          productId: productId,
        });
      }
    }

    // Wait for all deferred scripts to load
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initBuilder);
    } else {
      // Small delay to ensure deferred scripts have executed
      setTimeout(initBuilder, 100);
    }
  })();
</script>

{% schema %}
{
  "name": "Builder Modal",
  "target": "section",
  "templates": ["product"],
  "settings": [
    {
      "type": "paragraph",
      "content": "Adds a full-featured upload builder with Canvas preview and FitCheck mockups. Configure settings in the Upload Studio app dashboard."
    },

    {
      "type": "checkbox",
      "id": "show_header",
      "label": "Show header text",
      "default": true
    },
    {
      "type": "text",
      "id": "header_text",
      "label": "Header text",
      "default": "Build Your Transfer"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button text",
      "default": "Open Builder"
    },
    {
      "type": "color",
      "id": "btn_bg_color",
      "label": "Button background color",
      "default": "#16a34a"
    },
    {
      "type": "color",
      "id": "btn_text_color",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "btn_radius",
      "label": "Button border radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "default": 12,
      "unit": "px"
    },
    {
      "type": "checkbox",
      "id": "btn_full_width",
      "label": "Full width button",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_subtext",
      "label": "Show subtext",
      "default": true
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Supports PNG, JPG, PSD, SVG, PDF, AI, EPS • Max 10GB"
    }
  ]
}
{% endschema %}
