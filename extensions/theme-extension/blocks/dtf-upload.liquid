{% comment %}
  Upload Studio - DTF Transfer By Size Block
  =============================================
  Mode: dtf_by_size (Gang-sheet / DTF Transfer pricing by square inch)
  Location: Product page

  Renders:
  - Upload trigger zone with drag & drop
  - Full-featured modal (Canvas + FitCheck + Controls)
  - Client-side price calculation (W × H × Qty × $/in²)

  Config is hydrated from product metafields (dtf_app namespace)
  and passed to JS via data attributes — NO runtime API calls for config.

  Version: 1.0.0
{% endcomment %}

{% comment %}
  Pull product metafields — all DTF config from app backend admin panel
{% endcomment %}
{%- assign dtf_tiers    = product.metafields.dtf_app.volume_discount_tiers.value -%}
{%- assign max_w        = product.metafields.dtf_app.max_width_in.value | default: 21.75 -%}
{%- assign max_h        = product.metafields.dtf_app.max_height_in.value | default: 35.75 -%}
{%- assign min_w        = product.metafields.dtf_app.min_width_in.value | default: 1 -%}
{%- assign min_h        = product.metafields.dtf_app.min_height_in.value | default: 1 -%}
{%- assign color_profile = product.metafields.dtf_app.color_profile.value | default: "CMYK" -%}
{%- assign max_file_mb  = product.metafields.dtf_app.max_file_size_mb.value | default: 500 -%}
{%- assign formats      = product.metafields.dtf_app.supported_formats.value | default: '["PNG","JPG","JPEG","SVG","PSD","AI","EPS","PDF"]' -%}

{% comment %}
  Load shared dependencies (same as dtf-transfer.liquid)
{% endcomment %}
<script src="{{ 'ul-state.js' | asset_url }}" defer></script>
<script>
  window.ULCustomer = window.ULCustomer || {
    id: {{ customer.id | default: 'null' }},
    email: {{ customer.email | json | default: 'null' }}
  };
</script>
<script>
  (function() {
    try {
      if (window.location.hash === '#ul-customer-login-popup') {
        if (window.opener) {
          window.opener.postMessage({ type: 'ul-customer-login-success' }, window.location.origin);
          window.close();
          return;
        }
        if (window.history && typeof window.history.replaceState === 'function') {
          window.history.replaceState({}, document.title, window.location.pathname + window.location.search);
        }
      }
    } catch (error) {}
  })();
</script>
<script
  src="{{ 'ul-visitor.js' | asset_url }}"
  defer
  data-shop-domain="{{ shop.permanent_domain }}"
></script>

{% comment %}
  DTF By Size CSS + JS
{% endcomment %}
{{ 'dtf-upload.css' | asset_url | stylesheet_tag }}
<script src="{{ 'dtf-upload.js' | asset_url }}" defer></script>

{% comment %}
  Root element — JS reads config from data attributes
{% endcomment %}
<div
  id="dtf-upload-root"
  data-product-id="{{ product.id }}"
  data-product-title="{{ product.title | escape }}"
  data-product-variants="{{ product.variants | json | escape }}"
  data-product-options="{{ product.options_with_values | json | escape }}"
  data-shop-domain="{{ shop.permanent_domain }}"
  data-api-base="/apps/customizer"
  data-max-width="{{ max_w }}"
  data-max-height="{{ max_h }}"
  data-min-width="{{ min_w }}"
  data-min-height="{{ min_h }}"
  data-color-profile="{{ color_profile }}"
  data-max-file-mb="{{ max_file_mb }}"
  data-formats="{{ formats | escape }}"
  data-tiers="{{ dtf_tiers | escape }}"
  data-currency="{{ cart.currency.iso_code }}"
  data-locale="{{ request.locale.iso_code }}"
  data-account-login-url="{{ routes.account_login_url }}"
  data-account-url="/account"
  data-enable-fitcheck="{{ block.settings.enable_fitcheck }}"
>
  <div class="dtf-dropzone" id="dtf-trigger-zone">
    <button
      class="dtf-upload-trigger"
      type="button"
      aria-haspopup="dialog"
      aria-controls="dtf-modal"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
      {{ block.settings.button_label | default: 'UPLOAD YOUR FILE' }}
    </button>
    <p class="dtf-upload-trigger__hint">OR DROP FILES HERE</p>
    <p class="dtf-upload-trigger__formats">
      FILES SUPPORTED: PNG, JPG, SVG, PSD, AI, EPS, PDF<br/>
      MAX FILE SIZE: {{ max_file_mb }}MB
    </p>
    <div class="dtf-customer-status" aria-live="polite">
      <div class="dtf-customer-status__copy">
        <div class="dtf-customer-status__title">Guest checkout</div>
        <div class="dtf-customer-status__text">Log in to use your saved customer pricing on this page.</div>
      </div>
      <button class="dtf-btn dtf-btn--secondary dtf-customer-status__login" type="button">Log In</button>
      <a class="dtf-btn dtf-btn--ghost dtf-customer-status__account" href="/account" hidden>My Account</a>
    </div>
  </div>
</div>

{% comment %}
  Modal shell — body content rendered by dtf-upload.js
{% endcomment %}
<div id="dtf-modal" class="dtf-modal" role="dialog" aria-modal="true" aria-labelledby="dtf-modal-title" hidden>
  <div class="dtf-modal__backdrop"></div>
  <div class="dtf-modal__container">
    <header class="dtf-modal__header">
      <div class="dtf-modal__header-main">
        <button class="dtf-btn dtf-btn--primary dtf-modal__uploads-btn" type="button">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
          Uploads
        </button>
        <div class="dtf-modal__customer" aria-live="polite">
          <span class="dtf-modal__customer-badge">Guest</span>
          <div class="dtf-modal__customer-copy">
            <div class="dtf-modal__customer-title">Guest checkout</div>
            <div class="dtf-modal__customer-text">Log in to load your saved customer pricing before adding to cart.</div>
          </div>
          <button class="dtf-btn dtf-btn--secondary dtf-modal__customer-login" type="button">Log In</button>
          <a class="dtf-btn dtf-btn--ghost dtf-modal__customer-account" href="/account" hidden>My Account</a>
        </div>
      </div>
      <button class="dtf-modal__close" type="button" aria-label="Close">✕</button>
    </header>
    <div class="dtf-modal__body" id="dtf-modal-body"></div>
    <footer class="dtf-modal__footer">
      <button class="dtf-btn dtf-btn--primary dtf-btn--lg dtf-modal__add-to-cart" type="button" disabled>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
        Add To Cart
      </button>
    </footer>
  </div>
</div>

{% schema %}
{
  "name": "DTF Transfer By Size",
  "target": "section",
  "templates": ["product"],
  "settings": [
    {
      "type": "paragraph",
      "content": "DTF Transfer pricing by square inch. Configure volume discount tiers and dimension limits in the Upload Studio app dashboard."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Upload Button Label",
      "default": "UPLOAD YOUR FILE"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#22c55e"
    },
    {
      "type": "checkbox",
      "id": "enable_fitcheck",
      "label": "Enable FitCheck Preview",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_remove_bg",
      "label": "Show Remove Background Toggle",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_upscale",
      "label": "Show Upscale Quality Toggle",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_halftone",
      "label": "Show Halftone Toggle",
      "default": false
    }
  ]
}
{% endschema %}
