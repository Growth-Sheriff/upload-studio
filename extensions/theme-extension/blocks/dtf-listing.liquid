{%- assign mw=product.metafields.dtf_app.max_width_in.value|default:21.75-%}{%- assign mh=product.metafields.dtf_app.max_height_in.value|default:35.75-%}{%- assign nw=product.metafields.dtf_app.min_width_in.value|default:1-%}{%- assign nh=product.metafields.dtf_app.min_height_in.value|default:1-%}{%- assign dt=product.metafields.dtf_app.volume_discount_tiers.value-%}{%- assign mf=product.metafields.dtf_app.max_file_size_mb.value|default:500-%}{%- assign fm=product.metafields.dtf_app.supported_formats.value|default:'["PNG","JPG","JPEG","SVG","PSD","AI","EPS","PDF"]'-%}
<script src="{{ 'ul-state.js' | asset_url }}" defer></script><script>window.ULCustomer=window.ULCustomer||{id:{{customer.id|default:'null'}},email:{{customer.email|json|default:'null'}}};</script><script src="{{ 'ul-visitor.js' | asset_url }}" defer data-shop-domain="{{ shop.permanent_domain }}"></script>
{{ 'dtf-upload.css' | asset_url | stylesheet_tag }}{{ 'dtf-listing.css' | asset_url | stylesheet_tag }}<script src="{{ 'dtf-upload.js' | asset_url }}" defer></script><script src="{{ 'dtf-listing.js' | asset_url }}" defer></script>
<div id="dtf-upload-root" style="display:none" data-product-id="{{product.id}}" data-product-title="{{product.title|escape}}" data-shop-domain="{{shop.permanent_domain}}" data-api-base="/apps/customizer" data-max-width="{{mw}}" data-max-height="{{mh}}" data-min-width="{{nw}}" data-min-height="{{nh}}" data-max-file-mb="{{mf}}" data-formats="{{fm|escape}}" data-tiers="{{dt|escape}}" data-currency="{{cart.currency.iso_code}}" data-enable-fitcheck="true"><div class="dtf-dropzone" id="dtf-trigger-zone" style="display:none"><button class="dtf-upload-trigger" type="button" style="display:none">U</button><p class="dtf-upload-trigger__hint" style="display:none"></p></div></div>
<div id="dtf-modal" class="dtf-modal" role="dialog" aria-modal="true" hidden><div class="dtf-modal__backdrop"></div><div class="dtf-modal__container"><header class="dtf-modal__header"><button class="dtf-btn dtf-btn--primary dtf-modal__uploads-btn" type="button">Uploads</button><button class="dtf-modal__close" type="button" aria-label="Close">✕</button></header><div class="dtf-modal__body" id="dtf-modal-body"></div><footer class="dtf-modal__footer"><button class="dtf-btn dtf-btn--primary dtf-btn--lg dtf-modal__add-to-cart" type="button" disabled>Add To Cart</button></footer></div></div>
<div class="dtf-listing" id="dtf-listing-root"><div class="dtf-listing__grid">{%assign p1=block.settings.product_1%}{%assign p2=block.settings.product_2%}{%assign p3=block.settings.product_3%}{%assign p4=block.settings.product_4%}{%assign a=false%}{%if p1!=blank%}{%assign a=true%}{%endif%}{%if p2!=blank%}{%assign a=true%}{%endif%}{%if p3!=blank%}{%assign a=true%}{%endif%}{%if p4!=blank%}{%assign a=true%}{%endif%}{%if a%}{%if p1!=blank%}<div class="dtf-listing__card"><div class="dtf-listing__card-media">{%if p1.featured_image%}<img src="{{p1.featured_image|image_url:width:480}}" alt="{{p1.title|escape}}" loading="lazy">{%endif%}</div><div class="dtf-listing__card-body"><h3 class="dtf-listing__card-title">{{p1.title}}</h3><p class="dtf-listing__card-price">{{p1.price|money_without_trailing_zeros}}</p><button type="button" class="dtf-listing__upload-btn" data-product-id="{{p1.id}}" data-product-title="{{p1.title|escape}}" data-product-handle="{{p1.handle}}">Upload</button></div></div>{%endif%}{%if p2!=blank%}<div class="dtf-listing__card"><div class="dtf-listing__card-media">{%if p2.featured_image%}<img src="{{p2.featured_image|image_url:width:480}}" alt="{{p2.title|escape}}" loading="lazy">{%endif%}</div><div class="dtf-listing__card-body"><h3 class="dtf-listing__card-title">{{p2.title}}</h3><p class="dtf-listing__card-price">{{p2.price|money_without_trailing_zeros}}</p><button type="button" class="dtf-listing__upload-btn" data-product-id="{{p2.id}}" data-product-title="{{p2.title|escape}}" data-product-handle="{{p2.handle}}">Upload</button></div></div>{%endif%}{%if p3!=blank%}<div class="dtf-listing__card"><div class="dtf-listing__card-media">{%if p3.featured_image%}<img src="{{p3.featured_image|image_url:width:480}}" alt="{{p3.title|escape}}" loading="lazy">{%endif%}</div><div class="dtf-listing__card-body"><h3 class="dtf-listing__card-title">{{p3.title}}</h3><p class="dtf-listing__card-price">{{p3.price|money_without_trailing_zeros}}</p><button type="button" class="dtf-listing__upload-btn" data-product-id="{{p3.id}}" data-product-title="{{p3.title|escape}}" data-product-handle="{{p3.handle}}">Upload</button></div></div>{%endif%}{%if p4!=blank%}<div class="dtf-listing__card"><div class="dtf-listing__card-media">{%if p4.featured_image%}<img src="{{p4.featured_image|image_url:width:480}}" alt="{{p4.title|escape}}" loading="lazy">{%endif%}</div><div class="dtf-listing__card-body"><h3 class="dtf-listing__card-title">{{p4.title}}</h3><p class="dtf-listing__card-price">{{p4.price|money_without_trailing_zeros}}</p><button type="button" class="dtf-listing__upload-btn" data-product-id="{{p4.id}}" data-product-title="{{p4.title|escape}}" data-product-handle="{{p4.handle}}">Upload</button></div></div>{%endif%}{%else%}<p>Select products in block settings.</p>{%endif%}</div></div>
{% schema %}
{"name":"DTF Product Listing","target":"section","templates":["product","collection","index","page"],"settings":[{"type":"header","content":"Product 1"},{"type":"product","id":"product_1","label":"Product 1"},{"type":"header","content":"Product 2"},{"type":"product","id":"product_2","label":"Product 2"},{"type":"header","content":"Product 3"},{"type":"product","id":"product_3","label":"Product 3"},{"type":"header","content":"Product 4"},{"type":"product","id":"product_4","label":"Product 4"}]}
{% endschema %}
