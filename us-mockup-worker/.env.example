# Upload Studio — Mockup Worker Environment
# ═══════════════════════════════════════════════════════
# Copy to .env and fill in values

# Redis (same VPC as GSB, different DB index)
REDIS_URL=redis://10.130.237.107:6379/5

# PostgreSQL (Upload Studio databases, NOT gsb_engine)
# This worker connects to tenant DBs via DATABASE_URL
DATABASE_URL=postgresql://postgres:GCP_Mothership_2026!@34.44.26.92:5432/upload_studio?sslmode=prefer

# Cloudflare R2 Storage (shared bucket or separate)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=us-mockups
R2_PUBLIC_URL=
R2_ENDPOINT=

# Worker settings
WORKER_CONCURRENCY=2
QUEUE_NAME=us-mockup-queue
NODE_ENV=production
