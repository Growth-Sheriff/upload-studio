<script type="application/json" id="ul-hero-slot-data-{{ section.id }}">
[
{%- assign first_slot_json = true -%}
{% for block in section.blocks %}
{% if block.type == 'hero_card' %}
  {%- liquid
    assign card_type = block.settings.card_type | default: 'product'
    assign mode = block.settings.upload_mode | default: 'upload_studio'
    assign slot_url = blank
    assign target_product = blank
    assign slot_valid = false

    if block.settings.product != blank
      assign product_item = block.settings.product
      assign target_product = product_item
      assign slot_url = product_item.url
      assign slot_valid = true
    endif

    if block.settings.collection != blank
      assign collection_item = block.settings.collection
      assign collection_first_product = collection_item.products | first
      assign slot_valid = true

      if slot_url == blank
        assign slot_url = collection_item.url
      endif

      if target_product == blank
        if block.settings.linked_product != blank
          assign target_product = block.settings.linked_product
        elsif collection_first_product != blank
          assign target_product = collection_first_product
        endif
      endif
    endif
  -%}

  {% if slot_valid %}
    {% unless first_slot_json %},{% endunless %}
    {
      "id": {{ block.id | json }},
      "entityType": {{ card_type | json }},
      "mode": {{ mode | json }},
      "fallbackUrl": {{ slot_url | json }},
      "target": {% if target_product != blank %}{
        "id": {{ target_product.id }},
        "handle": {{ target_product.handle | json }},
        "title": {{ target_product.title | json }},
        "url": {{ target_product.url | json }},
        "options": {{ target_product.options_with_values | json }},
        "variants": {{ target_product.variants | json }},
        "metafields": {
          "tiers": {{ target_product.metafields.dtf_app.volume_discount_tiers.value | json | default: 'null' }},
          "max_width": {{ target_product.metafields.dtf_app.max_width_in.value | default: 22 }},
          "max_height": {{ target_product.metafields.dtf_app.max_height_in.value | default: 36 }}
        }
      }{% else %}null{% endif %}
    }
    {%- assign first_slot_json = false -%}
  {% endif %}
{% endif %}
{% endfor %}
]
</script>

<script>
;(function() {
  'use strict';

  var sectionId = {{ section.id | json }};
  var root = document.getElementById('ul-hero-banner-' + sectionId);
  if (!root) return;

  var SHOP_DOMAIN = {{ shop.permanent_domain | json }};
  var API_BASE = '/apps/customizer';

  function getSlots() {
    try {
      var el = document.getElementById('ul-hero-slot-data-' + sectionId);
      return el ? JSON.parse(el.textContent) : [];
    } catch (e) {
      return [];
    }
  }

  function getSlot(slotId) {
    var slots = getSlots();
    for (var i = 0; i < slots.length; i++) {
      if (String(slots[i].id) === String(slotId)) return slots[i];
    }
    return null;
  }

  function highlightCard(slotId) {
    var cards = root.querySelectorAll('.ul-hero-banner__card');
    for (var i = 0; i < cards.length; i++) {
      cards[i].classList.remove('ul-hero-banner__card--active');
    }

    var activeCard = root.querySelector('[data-card-id="' + slotId + '"]');
    if (activeCard) activeCard.classList.add('ul-hero-banner__card--active');
  }

  function openUploadStudio(target, fallbackUrl) {
    if (!target || !target.id) {
      if (fallbackUrl) window.location.href = fallbackUrl;
      return;
    }

    if (typeof window.ULDTFUploader === 'undefined') {
      window.location.href = target.url || ('/products/' + target.handle);
      return;
    }

    var productId = target.id;
    var productTitle = target.title || '';
    var variants = target.variants || [];
    var variantJson = JSON.stringify(variants);
    var firstVariant = variants.length ? variants[0] : { id: '', title: '-', price: 0 };

    var existingContainer = document.getElementById('ul-dtf-' + productId);
    if (existingContainer) existingContainer.remove();

    var modalBody = document.getElementById('ul-studio-modal-body');
    if (modalBody) modalBody.innerHTML = '';

    var containerHtml = '' +
      '<div id="ul-dtf-' + productId + '" class="ul-dtf-uploader"' +
      ' data-api-base="/apps/customizer"' +
      ' data-shop-domain="' + SHOP_DOMAIN + '"' +
      ' data-product-id="' + productId + '"' +
      ' data-product-title="' + (productTitle || '').replace(/"/g, '&quot;') + '">' +
      '<div class="ul-loading active" id="ul-loading-' + productId + '"><div class="ul-loading-spinner"></div><div>Loading configuration...</div></div>' +
      '<div class="ul-error" id="ul-error-' + productId + '">' +
        '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4m0 4h.01"/></svg>' +
        '<span id="ul-error-text-' + productId + '"></span>' +
      '</div>' +
      '<div id="ul-content-' + productId + '" style="display:none;">' +
        '<div class="ul-section" id="ul-upload-section-' + productId + '">' +
          '<div class="ul-section-header ul-section-header--centered">' +
            '<span class="ul-step-badge ul-step-badge--glow" id="ul-step-1-' + productId + '">1</span>' +
            '<span class="ul-section-title ul-section-title--hero">Upload Your Design</span>' +
          '</div>' +
          '<div class="ul-dropzone" id="ul-dropzone-' + productId + '">' +
            '<input type="file" id="ul-file-input-' + productId + '" accept=".png,.jpg,.jpeg,.webp,.tiff,.tif,.psd,.svg,.pdf,.ai,.eps">' +
            '<svg class="ul-dropzone-icon ul-bounce-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 16V4m0 0L8 8m4-4l4 4" stroke-linecap="round" stroke-linejoin="round"/><path d="M4 17v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2" stroke-linecap="round" stroke-linejoin="round"/></svg>' +
            '<div class="ul-dropzone-text ul-pulse-text">Drag & drop your design here</div>' +
            '<div class="ul-dropzone-hint">or click to browse - PNG, JPG, WEBP, TIFF, PSD, PDF, AI, EPS</div>' +
          '</div>' +
          '<div class="ul-upload-progress" id="ul-progress-' + productId + '">' +
            '<div class="ul-progress-bar"><div class="ul-progress-fill" id="ul-progress-fill-' + productId + '"></div></div>' +
            '<div class="ul-progress-info"><div class="ul-progress-text" id="ul-progress-text-' + productId + '">Uploading...</div>' +
              '<button type="button" class="ul-cancel-upload" id="ul-cancel-upload-' + productId + '" title="Cancel Upload"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="M18 6L6 18M6 6l12 12" stroke-linecap="round"/></svg>Cancel</button>' +
            '</div>' +
          '</div>' +
          '<div class="ul-file-preview" id="ul-preview-' + productId + '">' +
            '<img class="ul-file-thumb" id="ul-thumb-' + productId + '" src="" alt="Preview" width="72" height="72">' +
            '<div class="ul-file-info">' +
              '<div class="ul-file-name" id="ul-filename-' + productId + '"></div>' +
              '<div class="ul-file-meta" id="ul-filemeta-' + productId + '"></div>' +
              '<div class="ul-file-status" id="ul-filestatus-' + productId + '"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5" stroke-linecap="round" stroke-linejoin="round"/></svg><span>Ready</span></div>' +
            '</div>' +
            '<button type="button" class="ul-file-remove" id="ul-remove-' + productId + '" aria-label="Remove"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12" stroke-linecap="round"/></svg></button>' +
          '</div>' +
        '</div>' +
        '<div class="ul-section" id="ul-options-section-' + productId + '">' +
          '<div class="ul-section-header"><span class="ul-step-badge" id="ul-step-2-' + productId + '">2</span><span class="ul-section-title">Select Options</span></div>' +
          '<div class="ul-selected-variant-display" id="ul-selected-variant-' + productId + '">' +
            '<span class="ul-variant-name-display" id="ul-variant-name-' + productId + '">' + (firstVariant.title || '-') + '</span>' +
            '<span class="ul-variant-price-display" id="ul-variant-price-' + productId + '"></span>' +
          '</div>' +
          '<input type="hidden" id="ul-size-select-' + productId + '" value="' + (firstVariant.id || '') + '" data-price-raw="' + (firstVariant.price || 0) + '">' +
        '</div>' +
        '<script type="application/json" id="ul-variants-json-' + productId + '">' + variantJson + '<\/script>' +
        '<div class="ul-section" id="ul-qty-section-' + productId + '">' +
          '<div class="ul-section-header"><span class="ul-step-badge" id="ul-step-3-' + productId + '">3</span><span class="ul-section-title">Quantity</span></div>' +
          '<div class="ul-quantity-row"><div class="ul-quantity-control">' +
            '<button type="button" class="ul-qty-btn" id="ul-qty-minus-' + productId + '">-</button>' +
            '<input type="number" class="ul-qty-input" id="ul-qty-input-' + productId + '" value="1" min="1" max="999">' +
            '<button type="button" class="ul-qty-btn" id="ul-qty-plus-' + productId + '">+</button>' +
          '</div><div class="ul-bulk-hint" id="ul-bulk-hint-' + productId + '" style="display:none;"><span>Bulk discount!</span></div></div>' +
        '</div>' +
        '<div class="ul-section" id="ul-questions-section-' + productId + '" style="display:none;">' +
          '<div class="ul-section-header"><span class="ul-step-badge" id="ul-step-4-' + productId + '">4</span><span class="ul-section-title">Additional Options</span></div>' +
          '<div class="ul-questions-container" id="ul-questions-' + productId + '"></div>' +
        '</div>' +
        '<div class="ul-divider"></div>' +
        '<div class="ul-price-summary" id="ul-price-summary-' + productId + '">' +
          '<div class="ul-price-row"><span class="ul-price-label">Size (<span id="ul-selected-size-' + productId + '">-</span>)</span><span class="ul-price-value" id="ul-unit-price-' + productId + '">$0.00</span></div>' +
          '<div class="ul-price-row"><span class="ul-price-label">Quantity</span><span class="ul-price-value">x <span id="ul-qty-display-' + productId + '">1</span></span></div>' +
          '<div class="ul-price-row ul-price-total"><span class="ul-price-label">Total</span><span class="ul-price-value ul-price-total" id="ul-total-price-' + productId + '">$0.00</span></div>' +
        '</div>' +
        '<div class="ul-buttons-stack">' +
          '<button type="button" class="ul-btn ul-btn-secondary" id="ul-tshirt-btn-' + productId + '" style="display:none;" disabled><span>I want this on a T-Shirt too!</span></button>' +
          '<button type="button" class="ul-btn ul-btn-primary" id="ul-add-cart-' + productId + '" disabled>' +
            '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>' +
            '<span class="ul-btn-text">Add to Cart</span><span class="ul-btn-price" id="ul-btn-price-' + productId + '"></span>' +
          '</button>' +
        '</div>' +
      '</div>' +
      '<input type="hidden" id="ul-upload-id-' + productId + '" value="">' +
      '<input type="hidden" id="ul-upload-url-' + productId + '" value="">' +
      '<input type="hidden" id="ul-thumbnail-url-' + productId + '" value="">' +
    '</div>';

    if (modalBody) {
      modalBody.innerHTML = containerHtml;
    } else {
      document.body.insertAdjacentHTML('beforeend', containerHtml);
    }

    window.ULDTFUploader.init(productId);

    var studioModal = document.getElementById('ul-studio-modal');
    var modalTitle = document.getElementById('ul-studio-modal-title');
    if (studioModal) {
      studioModal.classList.add('active');
      document.body.style.overflow = 'hidden';
      if (modalTitle) modalTitle.textContent = productTitle || 'Upload Your Design';
    }

    function closeStudioModal() {
      if (studioModal) {
        studioModal.classList.remove('active');
        document.body.style.overflow = '';
      }
    }

    var closeBtn = document.getElementById('ul-studio-modal-close');
    var backdrop = document.getElementById('ul-studio-backdrop');
    if (closeBtn) closeBtn.onclick = closeStudioModal;
    if (backdrop) backdrop.onclick = closeStudioModal;
  }

  function openDtfBySize(target, fallbackUrl) {
    if (!target || !target.id) {
      if (fallbackUrl) window.location.href = fallbackUrl;
      return;
    }

    var uploadRoot = document.getElementById('dtf-upload-root');
    if (!uploadRoot) {
      window.location.href = target.url || ('/products/' + target.handle);
      return;
    }

    uploadRoot.setAttribute('data-product-id', target.id);
    uploadRoot.setAttribute('data-product-title', target.title || '');
    uploadRoot.setAttribute('data-product-variants', JSON.stringify(target.variants || []));
    uploadRoot.setAttribute('data-product-options', JSON.stringify(target.options || []));
    uploadRoot.removeAttribute('data-initialized');

    var dtfModalTitle = document.getElementById('dtf-modal-product-title');
    if (dtfModalTitle) dtfModalTitle.textContent = target.title || '';

    if (target.metafields) {
      uploadRoot.setAttribute('data-max-width', String(target.metafields.max_width || 22));
      uploadRoot.setAttribute('data-max-height', String(target.metafields.max_height || 36));
      if (target.metafields.tiers) {
        uploadRoot.setAttribute('data-tiers', JSON.stringify(target.metafields.tiers));
      }
    }

    if (window.dtfBlock) {
      window.dtfBlock.files = [];
      window.dtfBlock.activeFileIndex = -1;
      window.dtfBlock.state = 'IDLE';
      window.dtfBlock = null;
    }

    var config = {
      productId: target.id,
      productTitle: target.title || '',
      shopDomain: SHOP_DOMAIN,
      apiBase: API_BASE,
      maxWidth: parseFloat(uploadRoot.getAttribute('data-max-width')) || 22,
      maxHeight: parseFloat(uploadRoot.getAttribute('data-max-height')) || 36,
      minWidth: parseFloat(uploadRoot.getAttribute('data-min-width')) || 1,
      minHeight: parseFloat(uploadRoot.getAttribute('data-min-height')) || 1,
      maxFileMb: parseInt(uploadRoot.getAttribute('data-max-file-mb'), 10) || 500,
      formats: uploadRoot.getAttribute('data-formats'),
      tiers: uploadRoot.getAttribute('data-tiers'),
      productVariants: target.variants || [],
      productOptions: target.options || [],
      currency: uploadRoot.getAttribute('data-currency') || 'USD',
      enableFitcheck: uploadRoot.getAttribute('data-enable-fitcheck') !== 'false'
    };

    if (typeof window.DtfUploadBlock !== 'undefined') {
      window.dtfBlock = new window.DtfUploadBlock(config);
      window.dtfBlock.fetchConfigFallback();
      if (window.dtfBlock.fileInput) {
        window.dtfBlock.fileInput.click();
      }
      return;
    }

    window.location.href = target.url || ('/products/' + target.handle);
  }

  function openAutoSheet(target, fallbackUrl) {
    if (!target || !target.id) {
      if (fallbackUrl) window.location.href = fallbackUrl;
      return;
    }

    if (typeof window.ULAutoSheet === 'undefined') {
      window.location.href = target.url || ('/products/' + target.handle);
      return;
    }

    if (!window.ULAutoSheet.isEnabled()) {
      window.ULAutoSheet.init({ enabled: true });
    }

    var fileInput = document.createElement('input');
    fileInput.type = 'file';
    fileInput.accept = '.png,.jpg,.jpeg,.webp,.tiff,.tif,.psd,.pdf,.ai,.eps';
    fileInput.style.display = 'none';
    document.body.appendChild(fileInput);

    fileInput.addEventListener('change', function() {
      if (!fileInput.files || !fileInput.files[0]) return;

      var variants = target.variants || [];
      window.ULAutoSheet.openModal({
        file: fileInput.files[0],
        variants: variants,
        productId: target.id,
        shopDomain: SHOP_DOMAIN,
        quantity: 1,
        onSelect: function(result) {
          if (result && result.variantId) {
            fetch('/cart/add.js', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                id: result.variantId,
                quantity: result.sheetsNeeded || 1
              })
            }).then(function() {
              window.location.href = '/cart';
            });
          }
        }
      });

      document.body.removeChild(fileInput);
    });

    fileInput.click();
  }

  function handleClick(e) {
    e.preventDefault();

    var btn = e.currentTarget;
    var slotId = btn.getAttribute('data-slot-id');
    var slot = getSlot(slotId);
    if (!slot) return;

    highlightCard(slotId);

    var mode = slot.mode || btn.getAttribute('data-upload-mode') || 'upload_studio';
    var fallbackUrl = slot.fallbackUrl || '/';
    var target = slot.target;

    if (mode === 'redirect') {
      window.location.href = slot.entityType === 'collection' ? fallbackUrl : (target && target.url ? target.url : fallbackUrl);
      return;
    }

    if (mode === 'builder') {
      window.location.href = target && target.url ? target.url : fallbackUrl;
      return;
    }

    if (!target || !target.id) {
      if (fallbackUrl) {
        window.location.href = fallbackUrl;
      } else {
        alert('Please configure a linked product for this card.');
      }
      return;
    }

    if (mode === 'upload_studio') {
      openUploadStudio(target, fallbackUrl);
      return;
    }

    if (mode === 'dtf_by_size') {
      openDtfBySize(target, fallbackUrl);
      return;
    }

    if (mode === 'auto_sheet') {
      openAutoSheet(target, fallbackUrl);
    }
  }

  function initSlider() {
    var wrap = root.querySelector('.ul-hero-banner__slider-wrap');
    if (!wrap) return;

    var track = wrap.querySelector('.ul-hero-banner__grid');
    var prevBtn = wrap.querySelector('.ul-hero-banner__slider-btn--prev');
    var nextBtn = wrap.querySelector('.ul-hero-banner__slider-btn--next');
    if (!track) return;

    function updateArrows() {
      if (!prevBtn || !nextBtn) return;
      var sl = track.scrollLeft;
      var maxScroll = track.scrollWidth - track.clientWidth;
      prevBtn.disabled = sl <= 2;
      nextBtn.disabled = sl >= maxScroll - 2;
    }

    function scrollBy(dir) {
      var cardW = 298;
      track.scrollBy({ left: dir * cardW, behavior: 'smooth' });
    }

    if (prevBtn) prevBtn.addEventListener('click', function() { scrollBy(-1); });
    if (nextBtn) nextBtn.addEventListener('click', function() { scrollBy(1); });
    track.addEventListener('scroll', updateArrows, { passive: true });

    var isDragging = false;
    var startX = 0;
    var scrollStart = 0;

    track.addEventListener('mousedown', function(e) {
      isDragging = true;
      startX = e.pageX;
      scrollStart = track.scrollLeft;
      track.style.cursor = 'grabbing';
      track.style.scrollBehavior = 'auto';
    });

    document.addEventListener('mousemove', function(e) {
      if (!isDragging) return;
      e.preventDefault();
      var dx = e.pageX - startX;
      track.scrollLeft = scrollStart - dx;
    });

    document.addEventListener('mouseup', function() {
      if (!isDragging) return;
      isDragging = false;
      track.style.cursor = '';
      track.style.scrollBehavior = 'smooth';
    });

    setTimeout(updateArrows, 200);
  }

  function initSlideshow() {
    var slides = root.querySelectorAll('.ul-hero-banner__slide');
    var dots = root.querySelectorAll('.ul-hero-banner__dot');
    if (slides.length < 2) return;

    var current = 0;
    var total = slides.length;
    var autoRotate = {{ auto_rotate | json }};
    var rotateMs = {{ rotate_speed }} * 1000;
    var timer = null;
    var sliderWrap = root.querySelector('.ul-hero-banner__slider-wrap');

    function goTo(idx) {
      if (idx < 0) idx = total - 1;
      if (idx >= total) idx = 0;
      for (var i = 0; i < total; i++) {
        slides[i].classList.toggle('ul-hero-banner__slide--active', i === idx);
        if (dots[i]) dots[i].classList.toggle('ul-hero-banner__dot--active', i === idx);
      }
      current = idx;
      if (sliderWrap) {
        sliderWrap.style.opacity = idx === 0 ? '1' : '0';
        sliderWrap.style.pointerEvents = idx === 0 ? '' : 'none';
      }
    }

    for (var d = 0; d < dots.length; d++) {
      (function(idx) {
        dots[idx].addEventListener('click', function() {
          goTo(idx);
          resetTimer();
        });
      })(d);
    }

    function resetTimer() {
      if (timer) clearInterval(timer);
      if (autoRotate) {
        timer = setInterval(function() { goTo(current + 1); }, rotateMs);
      }
    }

    var touchStartX = 0;
    var frame = root.querySelector('.ul-hero-banner__frame');
    if (frame) {
      frame.addEventListener('touchstart', function(e) {
        touchStartX = e.touches[0].clientX;
      }, { passive: true });
      frame.addEventListener('touchend', function(e) {
        var dx = e.changedTouches[0].clientX - touchStartX;
        if (Math.abs(dx) > 50) {
          goTo(current + (dx < 0 ? 1 : -1));
          resetTimer();
        }
      }, { passive: true });
    }

    resetTimer();
  }

  function init() {
    var buttons = root.querySelectorAll('.ul-hero-banner__action');
    for (var i = 0; i < buttons.length; i++) {
      buttons[i].addEventListener('click', handleClick);
    }

    initSlider();
    initSlideshow();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    setTimeout(init, 150);
  }
})();
</script>

