{% comment %}
  DTF Hero Banner Section
  ------------------------------------------------------------------
  Manual theme section that combines:
  - Background image or background video
  - Heading/subheading content inside the banner area
  - Up to 4 foreground cards
  - Each card can represent a product or a collection
  - Each card can dispatch a different upload mode

  Notes:
  - Product cards use the selected product directly.
  - Collection cards display the collection, but upload flows target:
      1. linked_product, or
      2. first product in the collection
  - Assets are loaded from the app proxy, same approach as dtf-upload-section.
{% endcomment %}

{%- liquid
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign eyebrow = section.settings.eyebrow
  assign asset_base = '/apps/customizer/api/ext-assets/'

  assign has_upload_studio = false
  assign has_dtf_by_size = false
  assign has_auto_sheet = false
  assign slide_count = 0
  assign card_count = 0

  for block in section.blocks
    if block.type == 'banner_slide'
      assign slide_count = slide_count | plus: 1
    elsif block.type == 'hero_card'
      assign card_count = card_count | plus: 1
      if block.settings.upload_mode == 'upload_studio'
        assign has_upload_studio = true
      elsif block.settings.upload_mode == 'dtf_by_size'
        assign has_dtf_by_size = true
      elsif block.settings.upload_mode == 'auto_sheet'
        assign has_auto_sheet = true
      endif
    endif
  endfor

  assign overlay_alpha = section.settings.overlay_opacity | times: 0.01
  assign auto_rotate = section.settings.auto_rotate
  assign rotate_speed = section.settings.rotate_speed | default: 5
-%}

{% comment %} Shared assets {% endcomment %}
<link rel="stylesheet" href="{{ asset_base }}ul-common.css">

{% if has_upload_studio %}
  <link rel="stylesheet" href="{{ asset_base }}dtf-uploader.css">
  <link rel="stylesheet" href="{{ asset_base }}ul-hide-defaults.css">
  <link rel="stylesheet" href="{{ asset_base }}tshirt-modal.css">
  <link rel="stylesheet" href="{{ asset_base }}confirmation-screen.css">
{% endif %}

{% if has_dtf_by_size %}
  <link rel="stylesheet" href="{{ asset_base }}dtf-upload.css">
{% endif %}

{% if has_auto_sheet %}
  <link rel="stylesheet" href="{{ asset_base }}ul-auto-sheet.css">
{% endif %}

<script>
  window.ULCustomer = window.ULCustomer || {
    id: {{ customer.id | default: 'null' }},
    email: {{ customer.email | json | default: 'null' }}
  };
</script>
<script src="{{ asset_base }}ul-state.js" defer></script>
<script src="{{ asset_base }}ul-visitor.js" defer data-shop-domain="{{ shop.permanent_domain }}"></script>

{% if has_upload_studio %}
  <script src="{{ asset_base }}ul-remote-logger.js" defer></script>
  <script src="{{ asset_base }}ul-hide-defaults.js" defer></script>
  <script src="{{ asset_base }}ul-analytics.js" defer></script>
  <script src="{{ asset_base }}ul-error-handler.js" defer></script>
  <script src="{{ asset_base }}dtf-uploader.js" defer></script>
  <script src="{{ asset_base }}tshirt-modal.js" defer></script>
{% endif %}

{% if has_dtf_by_size %}
  <script src="{{ asset_base }}dtf-upload.js" defer></script>
{% endif %}

{% if has_auto_sheet %}
  <script src="{{ asset_base }}ul-dimension-reader.js" defer></script>
  <script src="{{ asset_base }}ul-nesting-engine.js" defer></script>
  <script src="{{ asset_base }}ul-sheet-optimizer.js" defer></script>
  <script src="{{ asset_base }}ul-sheet-simulator.js" defer></script>
  <script src="{{ asset_base }}ul-auto-sheet.js" defer></script>
{% endif %}

<style>
  #ul-hero-banner-{{ section.id }} {
    --ul-hero-radius: 28px;
    --ul-hero-shadow: 0 22px 70px rgba(15, 23, 42, 0.18);
    --ul-card-shadow: 0 12px 32px rgba(15, 23, 42, 0.12);
    --ul-card-border: rgba(255, 255, 255, 0.28);
    --ul-card-surface: rgba(255, 255, 255, 0.92);
    --ul-card-text: #101828;
    --ul-card-sub: #475467;
    --ul-button-bg: linear-gradient(135deg, #111827 0%, #1f2937 100%);
    --ul-button-hover: linear-gradient(135deg, #0f172a 0%, #111827 100%);
    --ul-min-height: {{ section.settings.min_height }}px;

    max-width: 1440px;
    margin: 0 auto;
    padding: 0 20px;
    box-sizing: border-box;
  }

  #ul-hero-banner-{{ section.id }} .ul-hero-banner__frame {
    position: relative;
    min-height: var(--ul-min-height);
    border-radius: var(--ul-hero-radius);
    overflow: hidden;
    box-shadow: var(--ul-hero-shadow);
    border: 1px solid rgba(255, 255, 255, 0.12);
    background:
      radial-gradient(circle at top left, rgba(255, 255, 255, 0.16), transparent 36%),
      linear-gradient(135deg, #0f172a 0%, #111827 55%, #1f2937 100%);
  }

  #ul-hero-banner-{{ section.id }} .ul-hero-banner__media,
  #ul-hero-banner-{{ section.id }} .ul-hero-banner__overlay {
    position: absolute;
    inset: 0;
  }

  #ul-hero-banner-{{ section.id }} .ul-hero-banner__picture {
    display: block;
    width: 100%;
    height: 100%;
  }

  #ul-hero-banner-{{ section.id }} .ul-hero-banner__media img,
  #ul-hero-banner-{{ section.id }} .ul-hero-banner__media picture img,
  #ul-hero-banner-{{ section.id }} .ul-hero-banner__media video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #ul-hero-banner-{{ section.id }} .ul-hero-banner__overlay {
    background:
      linear-gradient(180deg, rgba(15, 23, 42, 0.12) 0%, rgba(15, 23, 42, 0.45) 65%, rgba(15, 23, 42, 0.72) 100%),
      {{ section.settings.overlay_color | color_modify: 'alpha', overlay_alpha }};
  }

  #ul-hero-banner-{{ section.id }} .ul-hero-banner__inner {
    position: relative;
    z-index: 1;
    min-height: var(--ul-min-height);
    padding: clamp(28px, 4vw, 44px);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 28px;
  }

  #ul-hero-banner-{{ section.id }} .ul-hero-banner__intro {
    max-width: 760px;
    color: #ffffff;
  }

  #ul-hero-banner-{{ section.id }} .ul-hero-banner__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    margin-bottom: 14px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.14);
    border: 1px solid rgba(255, 255, 255, 0.18);
    backdrop-filter: blur(10px);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  #ul-hero-banner-{{ section.id }} .ul-hero-banner__title {
    margin: 0;
    font-size: clamp(30px, 4vw, 58px);
    line-height: 0.98;
    font-weight: 800;
    letter-spacing: -0.04em;
    text-wrap: balance;
  }

  #ul-hero-banner-{{ section.id }} .ul-hero-banner__subtitle {
    margin: 12px 0 0;
    max-width: 62ch;
    font-size: clamp(15px, 1.5vw, 19px);
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.84);
  }

  /* ── Banner Slideshow ── */
  #ul-hero-banner-{{ section.id }} .ul-hero-banner__slides {
    position: absolute;
    inset: 0;
  }

  #ul-hero-banner-{{ section.id }} .ul-hero-banner__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.8s ease;
    pointer-events: none;
  }

  #ul-hero-banner-{{ section.id }} .ul-hero-banner__slide--active {
    opacity: 1;
    pointer-events: auto;
  }

  #ul-hero-banner-{{ section.id }} .ul-hero-banner__slide-media {
    position: absolute;
    inset: 0;
  }

  #ul-hero-banner-{{ section.id }} .ul-hero-banner__media-asset--mobile {
    display: none;
  }

  #ul-hero-banner-{{ section.id }} .ul-hero-banner__slide-media img,
  #ul-hero-banner-{{ section.id }} .ul-hero-banner__slide-media picture img,
  #ul-hero-banner-{{ section.id }} .ul-hero-banner__slide-media video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #ul-hero-banner-{{ section.id }} .ul-hero-banner__slide-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(15, 23, 42, 0.12) 0%, rgba(15, 23, 42, 0.45) 65%, rgba(15, 23, 42, 0.72) 100%),
      {{ section.settings.overlay_color | color_modify: 'alpha', overlay_alpha }};
  }

  #ul-hero-banner-{{ section.id }} .ul-hero-banner__slide-content {
    position: relative;
    z-index: 1;
    max-width: 760px;
    color: #ffffff;
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(28px, 4vw, 44px);
  }

  #ul-hero-banner-{{ section.id }} .ul-hero-banner__dots {
    display: flex;
    gap: 8px;
    justify-content: center;
    padding: 14px 0 0;
  }

  #ul-hero-banner-{{ section.id }} .ul-hero-banner__spacer {
    flex: 1 1 auto;
    min-height: 0;
  }

  #ul-hero-banner-{{ section.id }} .ul-hero-banner__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.6);
    background: transparent;
    cursor: pointer;
    padding: 0;
    transition: background 0.25s, border-color 0.25s, transform 0.25s;
  }

  #ul-hero-banner-{{ section.id }} .ul-hero-banner__dot:hover {
    border-color: #fff;
    transform: scale(1.2);
  }

  #ul-hero-banner-{{ section.id }} .ul-hero-banner__dot--active {
    background: #ffffff;
    border-color: #ffffff;
  }

  /* ── Card Slider ── */
  #ul-hero-banner-{{ section.id }} .ul-hero-banner__slider-wrap {
    position: relative;
    transition: opacity 0.5s ease;
  }

  #ul-hero-banner-{{ section.id }} .ul-hero-banner__grid {
    display: flex;
    gap: 18px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 4px;
  }

  #ul-hero-banner-{{ section.id }} .ul-hero-banner__grid::-webkit-scrollbar {
    display: none;
  }

  #ul-hero-banner-{{ section.id }} .ul-hero-banner__grid > * {
    scroll-snap-align: start;
    flex: 0 0 280px;
  }

  #ul-hero-banner-{{ section.id }} .ul-hero-banner__slider-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 3;
    width: 40px;
    height: 40px;
    border: none;
    border-radius: 50%;
    background: rgba(255,255,255,0.92);
    color: #111827;
    box-shadow: 0 4px 14px rgba(0,0,0,0.18);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s, transform 0.2s, opacity 0.2s;
    opacity: 0;
    pointer-events: none;
  }

  #ul-hero-banner-{{ section.id }} .ul-hero-banner__slider-wrap:hover .ul-hero-banner__slider-btn {
    opacity: 1;
    pointer-events: auto;
  }

  #ul-hero-banner-{{ section.id }} .ul-hero-banner__slider-btn:hover {
    background: #ffffff;
    transform: translateY(-50%) scale(1.08);
  }

  #ul-hero-banner-{{ section.id }} .ul-hero-banner__slider-btn--prev {
    left: -16px;
  }

  #ul-hero-banner-{{ section.id }} .ul-hero-banner__slider-btn--next {
    right: -16px;
  }

  #ul-hero-banner-{{ section.id }} .ul-hero-banner__slider-btn[disabled] {
    opacity: 0 !important;
    pointer-events: none;
  }

  #ul-hero-banner-{{ section.id }} .ul-hero-banner__card {
    position: relative;
    display: flex;
    flex-direction: column;
    min-height: 308px;
    min-width: 280px;
    border-radius: 22px;
    overflow: hidden;
    background: var(--ul-card-surface);
    border: 1px solid var(--ul-card-border);
    box-shadow: var(--ul-card-shadow);
    backdrop-filter: blur(16px);
    transition: transform 0.28s ease, box-shadow 0.28s ease, border-color 0.28s ease;
    user-select: none;
  }

  #ul-hero-banner-{{ section.id }} .ul-hero-banner__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 18px 40px rgba(15, 23, 42, 0.18);
  }

  #ul-hero-banner-{{ section.id }} .ul-hero-banner__card--active {
    border-color: rgba(255, 255, 255, 0.9);
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.45), 0 18px 40px rgba(15, 23, 42, 0.2);
  }

  #ul-hero-banner-{{ section.id }} .ul-hero-banner__card-media {
    position: relative;
    aspect-ratio: 4 / 3;
    background: rgba(15, 23, 42, 0.12);
    overflow: hidden;
  }

  #ul-hero-banner-{{ section.id }} .ul-hero-banner__card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.45s ease;
  }

  #ul-hero-banner-{{ section.id }} .ul-hero-banner__card:hover .ul-hero-banner__card-media img {
    transform: scale(1.06);
  }

  #ul-hero-banner-{{ section.id }} .ul-hero-banner__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(15, 23, 42, 0.26);
    background:
      linear-gradient(135deg, rgba(148, 163, 184, 0.16), rgba(255, 255, 255, 0.6));
  }

  #ul-hero-banner-{{ section.id }} .ul-hero-banner__card-body {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 10px;
    padding: 18px 18px 18px;
  }

  #ul-hero-banner-{{ section.id }} .ul-hero-banner__badge {
    display: inline-flex;
    width: fit-content;
    align-items: center;
    gap: 6px;
    padding: 6px 10px;
    border-radius: 999px;
    background: rgba(15, 23, 42, 0.06);
    color: var(--ul-card-sub);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  #ul-hero-banner-{{ section.id }} .ul-hero-banner__card-title {
    margin: 0;
    color: var(--ul-card-text);
    font-size: 22px;
    line-height: 1.04;
    font-weight: 800;
    letter-spacing: -0.03em;
  }

  #ul-hero-banner-{{ section.id }} .ul-hero-banner__card-copy {
    margin: 0;
    color: var(--ul-card-sub);
    font-size: 14px;
    line-height: 1.45;
  }

  #ul-hero-banner-{{ section.id }} .ul-hero-banner__meta {
    margin-top: auto;
    color: var(--ul-card-text);
    font-size: 15px;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  #ul-hero-banner-{{ section.id }} .ul-hero-banner__action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    margin-top: 2px;
    padding: 13px 16px;
    border: none;
    border-radius: 14px;
    background: var(--ul-button-bg);
    color: #ffffff;
    cursor: pointer;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.01em;
    transition: background 0.25s ease, transform 0.2s ease, opacity 0.2s ease;
  }

  #ul-hero-banner-{{ section.id }} .ul-hero-banner__action:hover:not(:disabled) {
    background: var(--ul-button-hover);
    transform: translateY(-1px);
  }

  #ul-hero-banner-{{ section.id }} .ul-hero-banner__action:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  #ul-hero-banner-{{ section.id }} .ul-hero-banner__empty {
    flex: 0 0 100%;
    padding: 34px 20px;
    border-radius: 20px;
    text-align: center;
    color: rgba(255, 255, 255, 0.9);
    background: rgba(15, 23, 42, 0.28);
    border: 1px dashed rgba(255, 255, 255, 0.22);
    backdrop-filter: blur(10px);
  }

  @media (max-width: 1100px) {
    #ul-hero-banner-{{ section.id }} .ul-hero-banner__grid > * {
      flex: 0 0 260px;
    }
  }

  @media (max-width: 640px) {
    #ul-hero-banner-{{ section.id }} {
      padding: 0 12px;
    }

    #ul-hero-banner-{{ section.id }} .ul-hero-banner__frame {
      min-height: 420px;
      border-radius: 24px;
    }

    #ul-hero-banner-{{ section.id }} .ul-hero-banner__media-asset--desktop {
      display: none;
    }

    #ul-hero-banner-{{ section.id }} .ul-hero-banner__media-asset--mobile {
      display: block;
    }

    #ul-hero-banner-{{ section.id }} .ul-hero-banner__inner {
      min-height: 420px;
      padding: 14px 12px 12px;
      justify-content: flex-end;
      gap: 8px;
    }

    #ul-hero-banner-{{ section.id }} .ul-hero-banner__spacer {
      flex: 0 0 88px;
    }

    #ul-hero-banner-{{ section.id }} .ul-hero-banner__intro {
      max-width: 84%;
      margin-bottom: 0;
      padding-top: 0;
    }

    #ul-hero-banner-{{ section.id }} .ul-hero-banner__slide-content {
      max-width: 84%;
      justify-content: flex-start;
      padding: 44px 16px 108px;
    }

    #ul-hero-banner-{{ section.id }} .ul-hero-banner__eyebrow {
      margin-bottom: 10px;
      padding: 6px 12px;
      font-size: 11px;
    }

    #ul-hero-banner-{{ section.id }} .ul-hero-banner__title {
      font-size: clamp(24px, 8vw, 36px);
      line-height: 1.02;
    }

    #ul-hero-banner-{{ section.id }} .ul-hero-banner__subtitle {
      margin-top: 10px;
      font-size: 14px;
      line-height: 1.45;
    }

    #ul-hero-banner-{{ section.id }} .ul-hero-banner__grid {
      display: flex;
      flex-direction: column;
      gap: 14px;
      overflow: visible;
      scroll-snap-type: none;
      padding-bottom: 0;
    }

    #ul-hero-banner-{{ section.id }} .ul-hero-banner__grid > * {
      flex: 0 0 auto;
      width: 100%;
      min-width: 0;
    }

    #ul-hero-banner-{{ section.id }} .ul-hero-banner__card {
      min-height: 0;
      min-width: 0;
      flex-direction: row;
      align-items: center;
      border-radius: 18px;
      backdrop-filter: blur(12px);
    }

    #ul-hero-banner-{{ section.id }} .ul-hero-banner__card-media {
      display: none;
    }

    #ul-hero-banner-{{ section.id }} .ul-hero-banner__card-body {
      display: grid;
      width: 100%;
      grid-template-columns: minmax(0, 1fr) auto;
      column-gap: 12px;
      row-gap: 4px;
      align-items: center;
      padding: 12px 14px;
    }

    #ul-hero-banner-{{ section.id }} .ul-hero-banner__badge,
    #ul-hero-banner-{{ section.id }} .ul-hero-banner__card-copy,
    #ul-hero-banner-{{ section.id }} .ul-hero-banner__meta {
      display: none;
    }

    #ul-hero-banner-{{ section.id }} .ul-hero-banner__card-title {
      font-size: 16px;
      line-height: 1.15;
      grid-column: 1;
      align-self: center;
    }

    #ul-hero-banner-{{ section.id }} .ul-hero-banner__action {
      grid-column: 2;
      width: auto;
      margin: 0;
      padding: 10px 12px;
      border-radius: 12px;
      font-size: 12px;
      white-space: nowrap;
    }

    #ul-hero-banner-{{ section.id }} .ul-hero-banner__action svg {
      display: none;
    }

    #ul-hero-banner-{{ section.id }} .ul-hero-banner__dots {
      justify-content: flex-start;
      padding: 0 0 2px;
    }

    #ul-hero-banner-{{ section.id }} .ul-hero-banner__slider-btn {
      display: none;
    }
  }
</style>

<section id="ul-hero-banner-{{ section.id }}">
  <div class="ul-hero-banner__frame">

    {% if slide_count > 0 %}
      {%- comment -%} Multi-slide mode {%- endcomment -%}
      <div class="ul-hero-banner__slides">
        {%- assign slide_idx = 0 -%}
        {% for block in section.blocks %}
          {% if block.type == 'banner_slide' %}
          <div class="ul-hero-banner__slide{% if slide_idx == 0 %} ul-hero-banner__slide--active{% endif %}" data-slide-index="{{ slide_idx }}" {{ block.shopify_attributes }}>
            <div class="ul-hero-banner__slide-media" aria-hidden="true">
              {% if block.settings.slide_mode == 'video' and block.settings.slide_video_url != blank %}
                <video class="ul-hero-banner__media-asset--desktop" autoplay muted loop playsinline preload="metadata"
                  {% if block.settings.slide_poster != blank %}poster="{{ block.settings.slide_poster | image_url: width: 2000 }}"{% endif %}
                >
                  <source src="{{ block.settings.slide_video_url }}" type="video/mp4">
                </video>
                {% if block.settings.slide_mobile_image != blank %}
                  <img
                    class="ul-hero-banner__media-asset--mobile"
                    src="{{ block.settings.slide_mobile_image | image_url: width: 900 }}"
                    alt="{{ block.settings.slide_heading | escape }}"
                    loading="{% if slide_idx == 0 %}eager{% else %}lazy{% endif %}"
                    width="900"
                    height="1200"
                  >
                {% endif %}
              {% elsif block.settings.slide_image != blank or block.settings.slide_mobile_image != blank %}
                <picture class="ul-hero-banner__picture">
                  {% if block.settings.slide_mobile_image != blank %}
                    <source media="(max-width: 640px)" srcset="{{ block.settings.slide_mobile_image | image_url: width: 900 }}">
                  {% endif %}
                  <img
                    src="{% if block.settings.slide_image != blank %}{{ block.settings.slide_image | image_url: width: 2000 }}{% else %}{{ block.settings.slide_mobile_image | image_url: width: 900 }}{% endif %}"
                    alt="{{ block.settings.slide_heading | escape }}"
                    loading="{% if slide_idx == 0 %}eager{% else %}lazy{% endif %}"
                    width="2000" height="1200"
                  >
                </picture>
              {% endif %}
            </div>
            {% if block.settings.slide_image != blank or block.settings.slide_mobile_image != blank or block.settings.slide_video_url != blank %}
              <div class="ul-hero-banner__slide-overlay"></div>
            {% endif %}
            <div class="ul-hero-banner__slide-content">
              {% if block.settings.slide_eyebrow != blank %}
                <div class="ul-hero-banner__eyebrow">{{ block.settings.slide_eyebrow }}</div>
              {% endif %}
              {% if block.settings.slide_heading != blank %}
                <h2 class="ul-hero-banner__title">{{ block.settings.slide_heading }}</h2>
              {% endif %}
              {% if block.settings.slide_subheading != blank %}
                <p class="ul-hero-banner__subtitle">{{ block.settings.slide_subheading }}</p>
              {% endif %}
            </div>
          </div>
          {%- assign slide_idx = slide_idx | plus: 1 -%}
          {% endif %}
        {% endfor %}
      </div>

    {% else %}
      {%- comment -%} Fallback: section-level single background {%- endcomment -%}
      <div class="ul-hero-banner__media" aria-hidden="true">
        {% if section.settings.background_mode == 'video' and section.settings.background_video_url != blank %}
          <video class="ul-hero-banner__media-asset--desktop" autoplay muted loop playsinline preload="metadata"
            {% if section.settings.background_poster != blank %}poster="{{ section.settings.background_poster | image_url: width: 2000 }}"{% endif %}
          >
            <source src="{{ section.settings.background_video_url }}" type="video/mp4">
          </video>
          {% if section.settings.background_mobile_image != blank %}
            <img
              class="ul-hero-banner__media-asset--mobile"
              src="{{ section.settings.background_mobile_image | image_url: width: 900 }}"
              alt="{{ heading | escape }}"
              loading="lazy"
              width="900"
              height="1200"
            >
          {% endif %}
        {% elsif section.settings.background_image != blank or section.settings.background_mobile_image != blank %}
          <picture class="ul-hero-banner__picture">
            {% if section.settings.background_mobile_image != blank %}
              <source media="(max-width: 640px)" srcset="{{ section.settings.background_mobile_image | image_url: width: 900 }}">
            {% endif %}
            <img
              src="{% if section.settings.background_image != blank %}{{ section.settings.background_image | image_url: width: 2000 }}{% else %}{{ section.settings.background_mobile_image | image_url: width: 900 }}{% endif %}"
              alt="{{ heading | escape }}"
              loading="lazy"
              width="2000" height="1200"
            >
          </picture>
        {% endif %}
      </div>
      {% if section.settings.background_image != blank or section.settings.background_mobile_image != blank or section.settings.background_video_url != blank %}
        <div class="ul-hero-banner__overlay"></div>
      {% endif %}
    {% endif %}

    <div class="ul-hero-banner__inner">
      {% if slide_count == 0 %}
        {% if eyebrow != blank or heading != blank or subheading != blank %}
          <div class="ul-hero-banner__intro">
            {% if eyebrow != blank %}
              <div class="ul-hero-banner__eyebrow">{{ eyebrow }}</div>
            {% endif %}
            {% if heading != blank %}
              <h2 class="ul-hero-banner__title">{{ heading }}</h2>
            {% endif %}
            {% if subheading != blank %}
              <p class="ul-hero-banner__subtitle">{{ subheading }}</p>
            {% endif %}
          </div>
        {% endif %}
      {% else %}
        {%- comment -%} Spacer for slide content area + dots {%- endcomment -%}
        <div class="ul-hero-banner__spacer"></div>
        {% if slide_count > 1 %}
          <div class="ul-hero-banner__dots">
            {%- assign dot_idx = 0 -%}
            {% for block in section.blocks %}
              {% if block.type == 'banner_slide' %}
                <button type="button" class="ul-hero-banner__dot{% if dot_idx == 0 %} ul-hero-banner__dot--active{% endif %}" data-slide-goto="{{ dot_idx }}" aria-label="Slide {{ dot_idx | plus: 1 }}"></button>
                {%- assign dot_idx = dot_idx | plus: 1 -%}
              {% endif %}
            {% endfor %}
          </div>
        {% endif %}
      {% endif %}

      <div class="ul-hero-banner__slider-wrap">
        <button type="button" class="ul-hero-banner__slider-btn ul-hero-banner__slider-btn--prev" aria-label="Previous" disabled>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        </button>
        <button type="button" class="ul-hero-banner__slider-btn ul-hero-banner__slider-btn--next" aria-label="Next">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18"></polyline></svg>
        </button>
        <div class="ul-hero-banner__grid">
        {% for block in section.blocks %}
          {% if block.type == 'hero_card' %}
          {%- liquid
            assign card_type = block.settings.card_type | default: 'product'
            assign mode = block.settings.upload_mode | default: 'upload_studio'
            assign button_text = block.settings.button_text | default: 'Upload Design'

            assign display_title = blank
            assign display_copy = block.settings.card_copy
            assign display_meta = blank
            assign display_image = block.settings.card_image
            assign target_product = blank
            assign card_ready = true

            if block.settings.product != blank
              assign product_item = block.settings.product
              assign target_product = product_item
              assign display_title = product_item.title
              assign display_meta = product_item.price | money_without_trailing_zeros

              if display_image == blank and product_item.featured_image != blank
                assign display_image = product_item.featured_image
              endif
            endif

            if block.settings.collection != blank
              assign collection_item = block.settings.collection
              assign collection_first_product = collection_item.products | first

              if display_title == blank
                assign display_title = collection_item.title
              endif
              if display_meta == blank
                assign display_meta = 'Collection'
              endif

              if target_product == blank
                if block.settings.linked_product != blank
                  assign target_product = block.settings.linked_product
                elsif collection_first_product != blank
                  assign target_product = collection_first_product
                endif
              endif

              if display_image == blank and collection_item.image != blank
                assign display_image = collection_item.image
              elsif display_image == blank and collection_first_product != blank and collection_first_product.featured_image != blank
                assign display_image = collection_first_product.featured_image
              endif
            endif

            if block.settings.title_override != blank
              assign display_title = block.settings.title_override
            endif

            if display_title == blank
              assign display_title = 'Hero Card'
            endif

            if display_copy == blank
              if card_type == 'product'
                assign display_copy = 'Choose this product and start your upload flow directly from the banner.'
              else
                assign display_copy = 'Display a collection card and route uploads through its linked product.'
              endif
            endif

            assign action_disabled = false
            if target_product == blank and mode != 'redirect' and mode != 'builder'
              assign action_disabled = true
            endif
          -%}

            <article class="ul-hero-banner__card" data-card-id="{{ block.id }}" {{ block.shopify_attributes }}>
              <div class="ul-hero-banner__card-media">
                {% if display_image != blank %}
                  <img
                    src="{{ display_image | image_url: width: 960 }}"
                    alt="{{ display_title | escape }}"
                    loading="lazy"
                    width="960"
                    height="720"
                  >
                {% else %}
                  <div class="ul-hero-banner__placeholder">
                    <svg width="52" height="52" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25">
                      <rect x="3" y="3" width="18" height="18" rx="2"></rect>
                      <circle cx="8.5" cy="8.5" r="1.5"></circle>
                      <path d="M21 15l-5-5L5 21"></path>
                    </svg>
                  </div>
                {% endif %}
              </div>

              <div class="ul-hero-banner__card-body">
                <div class="ul-hero-banner__badge">{% if card_type == 'product' %}Product{% else %}Collection{% endif %}</div>
                <h3 class="ul-hero-banner__card-title">{{ display_title }}</h3>
                <p class="ul-hero-banner__card-copy">{{ display_copy }}</p>
                <div class="ul-hero-banner__meta">{{ display_meta }}</div>
                <button
                  type="button"
                  class="ul-hero-banner__action"
                  data-slot-id="{{ block.id }}"
                  data-upload-mode="{{ mode }}"
                  {% if action_disabled %}disabled{% endif %}
                >
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                    <polyline points="17 8 12 3 7 8"></polyline>
                    <line x1="12" y1="3" x2="12" y2="15"></line>
                  </svg>
                  <span>{{ button_text }}</span>
                </button>
              </div>
            </article>
          {% endif %}
        {% endfor %}

        {% if card_count == 0 %}
          <div class="ul-hero-banner__empty">
            Add Hero Card blocks from the section settings.
          </div>
        {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

