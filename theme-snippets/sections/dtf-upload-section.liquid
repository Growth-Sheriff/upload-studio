{% comment %}
  ═══════════════════════════════════════════════════════════════════════
  Upload Studio — DTF Product Listing (Self-Contained Theme Section)
  ═══════════════════════════════════════════════════════════════════════
  Standalone section — Shopify extension block limitlerini aşmak için
  temanın sections/ klasörüne doğrudan kopyalanır.

  Asset'ler kendi sunucumuzdan yüklenir (/apps/customizer/api/ext-assets/)
  Extension CDN'e bağımlılık yok.

  Her ürüne farklı mod atanabilir:
  - upload_studio  → DTF Uploader (dtf-uploader.js + modal)
  - dtf_by_size    → DTF Transfer By Size (dtf-upload.js + modal)
  - auto_sheet     → Auto Sheet Calculator (ul-auto-sheet.js + modal)
  - builder        → Gang Sheet Builder sayfasına yönlendir
  - redirect       → Ürün sayfasına yönlendir

  Kurulum:
  1. Bu dosyayı temanın sections/ klasörüne kopyala
  2. Theme Editor → Add Section → "DTF Product Listing"
  3. Ürünleri seç, her birine mod ve buton yazısı ata
  ═══════════════════════════════════════════════════════════════════════
{% endcomment %}

{%- liquid
  assign heading    = section.settings.heading
  assign subheading = section.settings.subheading
  assign asset_base = 'https://eagledtfprint.uploadstudio.app.techifyboost.com/api/ext-assets/'
-%}

{% comment %} ══════════ ASSET LOADING ══════════ {% endcomment %}
{% comment %}
  Collect which modes are used so we only load needed assets.
  We always load shared deps (ul-state, ul-visitor, ul-common).
{% endcomment %}

{%- liquid
  assign has_upload_studio = false
  assign has_dtf_by_size   = false
  assign has_auto_sheet    = false

  for block in section.blocks
    if block.settings.upload_mode == 'upload_studio'
      assign has_upload_studio = true
    elsif block.settings.upload_mode == 'dtf_by_size'
      assign has_dtf_by_size = true
    elsif block.settings.upload_mode == 'auto_sheet'
      assign has_auto_sheet = true
    endif
  endfor
-%}

{% comment %} ── Shared CSS ── {% endcomment %}
<link rel="stylesheet" href="{{ asset_base }}ul-common.css">
<link rel="stylesheet" href="{{ asset_base }}dtf-listing.css">

{% comment %} ── Mode-specific CSS ── {% endcomment %}
{% if has_upload_studio %}
  <link rel="stylesheet" href="{{ asset_base }}dtf-uploader.css">
  <link rel="stylesheet" href="{{ asset_base }}ul-hide-defaults.css">
  <link rel="stylesheet" href="{{ asset_base }}tshirt-modal.css">
  <link rel="stylesheet" href="{{ asset_base }}confirmation-screen.css">
{% endif %}

{% if has_dtf_by_size %}
  <link rel="stylesheet" href="{{ asset_base }}dtf-upload.css">
{% endif %}

{% if has_auto_sheet %}
  <link rel="stylesheet" href="{{ asset_base }}ul-auto-sheet.css">
{% endif %}

{% comment %} ── Shared JS ── {% endcomment %}
<script>
  window.ULCustomer = window.ULCustomer || {
    id: {{ customer.id | default: 'null' }},
    email: {{ customer.email | json | default: 'null' }}
  };
</script>
<script src="{{ asset_base }}ul-state.js" defer></script>
<script src="{{ asset_base }}ul-visitor.js" defer data-shop-domain="{{ shop.permanent_domain }}"></script>

{% comment %} ── Upload Studio assets ── {% endcomment %}
{% if has_upload_studio %}
  <script src="{{ asset_base }}ul-remote-logger.js" defer></script>
  <script src="{{ asset_base }}ul-hide-defaults.js" defer></script>
  <script src="{{ asset_base }}ul-analytics.js" defer></script>
  <script src="{{ asset_base }}ul-error-handler.js" defer></script>
  <script src="{{ asset_base }}dtf-uploader.js" defer></script>
  <script src="{{ asset_base }}tshirt-modal.js" defer></script>
{% endif %}

{% comment %} ── DTF By Size assets ── {% endcomment %}
{% if has_dtf_by_size %}
  <script src="{{ asset_base }}dtf-upload.js" defer></script>
{% endif %}

{% comment %} ── Auto Sheet Calculator assets ── {% endcomment %}
{% if has_auto_sheet %}
  <script src="{{ asset_base }}ul-dimension-reader.js" defer></script>
  <script src="{{ asset_base }}ul-nesting-engine.js" defer></script>
  <script src="{{ asset_base }}ul-sheet-optimizer.js" defer></script>
  <script src="{{ asset_base }}ul-sheet-simulator.js" defer></script>
  <script src="{{ asset_base }}ul-auto-sheet.js" defer></script>
{% endif %}


{% comment %} ══════════ PRODUCT LISTING GRID ══════════ {% endcomment %}
<div class="dtf-listing" id="dtf-listing-root">
  {% if heading != blank %}
    <div class="dtf-listing__header">
      <h2 class="dtf-listing__title">{{ heading }}</h2>
      {% if subheading != blank %}
        <p class="dtf-listing__subtitle">{{ subheading }}</p>
      {% endif %}
    </div>
  {% endif %}

  <div class="dtf-listing__grid">
    {% for block in section.blocks %}
      {%- assign item     = block.settings.product -%}
      {%- assign mode     = block.settings.upload_mode | default: 'upload_studio' -%}
      {%- assign btn_text = block.settings.button_text | default: 'Upload Design' -%}

      {% if item != blank %}
        <div class="dtf-listing__card" {{ block.shopify_attributes }}>
          <div class="dtf-listing__card-media">
            {% if item.featured_image %}
              <img
                src="{{ item.featured_image | image_url: width: 480 }}"
                alt="{{ item.title | escape }}"
                loading="lazy"
                width="240"
                height="240"
              >
            {% else %}
              <div class="dtf-listing__card-placeholder">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                  <rect x="3" y="3" width="18" height="18" rx="2"/>
                  <circle cx="8.5" cy="8.5" r="1.5"/>
                  <path d="m21 15-5-5L5 21"/>
                </svg>
              </div>
            {% endif %}
          </div>
          <div class="dtf-listing__card-body">
            <h3 class="dtf-listing__card-title">{{ item.title }}</h3>
            <p class="dtf-listing__card-price">{{ item.price | money_without_trailing_zeros }}</p>
            <button
              type="button"
              class="dtf-listing__upload-btn"
              data-product-id="{{ item.id }}"
              data-product-title="{{ item.title | escape }}"
              data-product-handle="{{ item.handle }}"
              data-upload-mode="{{ mode }}"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                <polyline points="17 8 12 3 7 8"/>
                <line x1="12" y1="3" x2="12" y2="15"/>
              </svg>
              {{ btn_text }}
            </button>
          </div>
        </div>
      {% endif %}
    {% endfor %}

    {% if section.blocks.size == 0 %}
      <div class="dtf-listing__empty">
        <p>Section ayarlarından ürün ekleyin.</p>
      </div>
    {% endif %}
  </div>
</div>


{% comment %} ══════════ HIDDEN ROOTS & MODALS ══════════ {% endcomment %}

{% comment %} ── DTF By Size: Hidden root + Modal ── {% endcomment %}
{% if has_dtf_by_size %}
  <div
    id="dtf-upload-root"
    style="display:none"
    data-shop-domain="{{ shop.permanent_domain }}"
    data-api-base="/apps/customizer"
    data-max-width="22"
    data-max-height="36"
    data-min-width="1"
    data-min-height="1"
    data-max-file-mb="500"
    data-formats='["PNG","JPG","JPEG","SVG","PSD","AI","EPS","PDF","TIFF","WEBP"]'
    data-currency="{{ cart.currency.iso_code }}"
    data-enable-fitcheck="true"
  >
    <div class="dtf-dropzone" id="dtf-trigger-zone" style="display:none">
      <button class="dtf-upload-trigger" type="button" style="display:none">U</button>
    </div>
  </div>

  <div id="dtf-modal" class="dtf-modal" role="dialog" aria-modal="true" hidden>
    <div class="dtf-modal__backdrop"></div>
    <div class="dtf-modal__container">
      <header class="dtf-modal__header">
        <button class="dtf-btn dtf-btn--primary dtf-modal__uploads-btn" type="button">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
          Uploads
        </button>
        <button class="dtf-modal__close" type="button" aria-label="Close">&#x2715;</button>
      </header>
      <div class="dtf-modal__body" id="dtf-modal-body"></div>
      <footer class="dtf-modal__footer">
        <button class="dtf-btn dtf-btn--primary dtf-btn--lg dtf-modal__add-to-cart" type="button" disabled>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
          Add To Cart
        </button>
      </footer>
    </div>
  </div>
{% endif %}

{% comment %} ── Upload Studio: Modal Wrapper ── {% endcomment %}
{% if has_upload_studio %}
  <style>
    .ul-studio-modal { position:fixed; inset:0; z-index:999999; display:none; align-items:center; justify-content:center; font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif; }
    .ul-studio-modal.active { display:flex; }
    .ul-studio-modal__backdrop { position:absolute; inset:0; background:rgba(0,0,0,0.6); backdrop-filter:blur(4px); }
    .ul-studio-modal__container { position:relative; width:95vw; max-width:680px; max-height:90vh; background:#fff; border-radius:12px; box-shadow:0 25px 60px rgba(0,0,0,0.3); display:flex; flex-direction:column; overflow:hidden; }
    .ul-studio-modal__header { display:flex; align-items:center; justify-content:space-between; padding:16px 20px; border-bottom:1px solid #e5e7eb; }
    .ul-studio-modal__title { font-size:16px; font-weight:600; margin:0; }
    .ul-studio-modal__close { background:none; border:none; font-size:22px; cursor:pointer; padding:4px 8px; color:#6b7280; border-radius:6px; }
    .ul-studio-modal__close:hover { background:#f3f4f6; color:#111827; }
    .ul-studio-modal__body { flex:1; overflow-y:auto; padding:0; }
    .ul-studio-modal__body .ul-dtf-uploader { padding:20px; }
  </style>

  <div id="ul-studio-modal" class="ul-studio-modal">
    <div class="ul-studio-modal__backdrop" id="ul-studio-backdrop"></div>
    <div class="ul-studio-modal__container">
      <div class="ul-studio-modal__header">
        <h3 class="ul-studio-modal__title" id="ul-studio-modal-title">Upload Your Design</h3>
        <button class="ul-studio-modal__close" id="ul-studio-modal-close" type="button" aria-label="Close">&#x2715;</button>
      </div>
      <div class="ul-studio-modal__body" id="ul-studio-modal-body">
        <!-- Dynamic ULDTFUploader container will be inserted here -->
      </div>
    </div>
  </div>
{% endif %}

{% comment %} ── Auto Sheet Calculator: will be rendered per-product ── {% endcomment %}
{% if has_auto_sheet %}
  <div id="ul-auto-sheet-root" style="display:none"
    data-shop-domain="{{ shop.permanent_domain }}"
    data-asset-base="{{ asset_base }}"
  ></div>
{% endif %}


{% comment %} ══════════ PRODUCT DATA JSON ══════════ {% endcomment %}
<script type="application/json" id="dtf-listing-products">
[{% for block in section.blocks %}{%- assign item = block.settings.product -%}{% if item != blank %}{% unless forloop.first %},{% endunless %}{
  "id": {{ item.id }},
  "handle": "{{ item.handle }}",
  "title": {{ item.title | json }},
  "price": {{ item.price }},
  "variants": {{ item.variants | json }},
  "mode": {{ block.settings.upload_mode | json }},
  "metafields": {
    "tiers": {{ item.metafields.dtf_app.volume_discount_tiers.value | json | default: 'null' }},
    "max_width": {{ item.metafields.dtf_app.max_width_in.value | default: 22 }},
    "max_height": {{ item.metafields.dtf_app.max_height_in.value | default: 36 }}
  }
}{% endif %}{% endfor %}]
</script>


{% comment %} ══════════ LISTING CONTROLLER ══════════ {% endcomment %}
<script>
;(function() {
  'use strict';

  var ASSET_BASE = {{ asset_base | json }};
  var SHOP_DOMAIN = {{ shop.permanent_domain | json }};
  var API_BASE = '/apps/customizer';

  function initListing() {
    var root = document.getElementById('dtf-listing-root');
    if (!root) return;

    var btns = root.querySelectorAll('.dtf-listing__upload-btn');
    if (!btns.length) return;

    for (var i = 0; i < btns.length; i++) {
      btns[i].addEventListener('click', handleClick);
    }
  }

  function getProductData(productId) {
    try {
      var el = document.getElementById('dtf-listing-products');
      if (!el) return null;
      var products = JSON.parse(el.textContent);
      for (var i = 0; i < products.length; i++) {
        if (String(products[i].id) === String(productId)) return products[i];
      }
    } catch (e) {}
    return null;
  }

  function handleClick(e) {
    e.preventDefault();
    var btn  = e.currentTarget;
    var productId    = btn.getAttribute('data-product-id');
    var productTitle = btn.getAttribute('data-product-title');
    var productHandle = btn.getAttribute('data-product-handle');
    var mode = btn.getAttribute('data-upload-mode') || 'upload_studio';

    // Highlight active card
    var cards = document.querySelectorAll('.dtf-listing__card');
    for (var c = 0; c < cards.length; c++) cards[c].classList.remove('dtf-listing__card--active');
    var card = btn.closest('.dtf-listing__card');
    if (card) card.classList.add('dtf-listing__card--active');

    var productData = getProductData(productId);


    /* ─── Mode: redirect / builder ─── */
    if (mode === 'redirect' || mode === 'builder') {
      window.location.href = '/products/' + productHandle;
      return;
    }


    /* ─── Mode: upload_studio ─── */
    if (mode === 'upload_studio') {
      if (typeof window.ULDTFUploader !== 'undefined') {
        // Remove existing container if any
        var existingContainer = document.getElementById('ul-dtf-' + productId);
        if (existingContainer) existingContainer.remove();

        // Clear modal body
        var modalBody = document.getElementById('ul-studio-modal-body');
        if (modalBody) modalBody.innerHTML = '';

        // Build the full DOM container that ULDTFUploader expects
        var variants = productData ? productData.variants : [];
        var variantJson = JSON.stringify(variants);
        var firstVariant = variants.length ? variants[0] : { id: '', title: '-', price: 0 };

        // Build option dropdowns HTML from variants
        var optionGroupsHtml = '';
        if (variants.length > 0 && variants[0].options) {
          // Collect unique option names and values
          var optionNames = [];
          var optionValues = {};
          for (var vi = 0; vi < variants.length; vi++) {
            var v = variants[vi];
            if (v.options) {
              for (var oi = 0; oi < v.options.length; oi++) {
                if (optionNames.indexOf(v.option1 ? 'Option ' + (oi+1) : '') < 0) {
                  // simplified: use title parsing
                }
              }
            }
          }
        }

        var containerHtml = '' +
          '<div id="ul-dtf-' + productId + '" class="ul-dtf-uploader"' +
          ' data-api-base="/apps/customizer"' +
          ' data-shop-domain="' + SHOP_DOMAIN + '"' +
          ' data-product-id="' + productId + '"' +
          ' data-product-title="' + (productTitle || '').replace(/"/g, '&quot;') + '">' +
          '<div class="ul-loading active" id="ul-loading-' + productId + '"><div class="ul-loading-spinner"></div><div>Loading configuration...</div></div>' +
          '<div class="ul-error" id="ul-error-' + productId + '">' +
            '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4m0 4h.01"/></svg>' +
            '<span id="ul-error-text-' + productId + '"></span>' +
          '</div>' +
          '<div id="ul-content-' + productId + '" style="display:none;">' +
            '<div class="ul-section" id="ul-upload-section-' + productId + '">' +
              '<div class="ul-section-header ul-section-header--centered">' +
                '<span class="ul-step-badge ul-step-badge--glow" id="ul-step-1-' + productId + '">1</span>' +
                '<span class="ul-section-title ul-section-title--hero">Upload Your Design</span>' +
              '</div>' +
              '<div class="ul-dropzone" id="ul-dropzone-' + productId + '">' +
                '<input type="file" id="ul-file-input-' + productId + '" accept=".png,.jpg,.jpeg,.webp,.tiff,.tif,.psd,.svg,.pdf,.ai,.eps">' +
                '<svg class="ul-dropzone-icon ul-bounce-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 16V4m0 0L8 8m4-4l4 4" stroke-linecap="round" stroke-linejoin="round"/><path d="M4 17v2a2 2 0 002 2h12a2 2 0 002-2v-2" stroke-linecap="round" stroke-linejoin="round"/></svg>' +
                '<div class="ul-dropzone-text ul-pulse-text">Drag & drop your design here</div>' +
                '<div class="ul-dropzone-hint">or click to browse • PNG, JPG, WEBP, TIFF, PSD, PDF, AI, EPS</div>' +
              '</div>' +
              '<div class="ul-upload-progress" id="ul-progress-' + productId + '">' +
                '<div class="ul-progress-bar"><div class="ul-progress-fill" id="ul-progress-fill-' + productId + '"></div></div>' +
                '<div class="ul-progress-info"><div class="ul-progress-text" id="ul-progress-text-' + productId + '">Uploading...</div>' +
                  '<button type="button" class="ul-cancel-upload" id="ul-cancel-upload-' + productId + '" title="Cancel Upload"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="M18 6L6 18M6 6l12 12" stroke-linecap="round"/></svg>Cancel</button>' +
                '</div>' +
              '</div>' +
              '<div class="ul-file-preview" id="ul-preview-' + productId + '">' +
                '<img class="ul-file-thumb" id="ul-thumb-' + productId + '" src="" alt="Preview" width="72" height="72">' +
                '<div class="ul-file-info">' +
                  '<div class="ul-file-name" id="ul-filename-' + productId + '"></div>' +
                  '<div class="ul-file-meta" id="ul-filemeta-' + productId + '"></div>' +
                  '<div class="ul-file-status" id="ul-filestatus-' + productId + '"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5" stroke-linecap="round" stroke-linejoin="round"/></svg><span>Ready</span></div>' +
                '</div>' +
                '<button type="button" class="ul-file-remove" id="ul-remove-' + productId + '" aria-label="Remove"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12" stroke-linecap="round"/></svg></button>' +
              '</div>' +
            '</div>' +
            '<div class="ul-section" id="ul-options-section-' + productId + '">' +
              '<div class="ul-section-header"><span class="ul-step-badge" id="ul-step-2-' + productId + '">2</span><span class="ul-section-title">Select Options</span></div>' +
              '<div class="ul-selected-variant-display" id="ul-selected-variant-' + productId + '">' +
                '<span class="ul-variant-name-display" id="ul-variant-name-' + productId + '">' + (firstVariant.title || '-') + '</span>' +
                '<span class="ul-variant-price-display" id="ul-variant-price-' + productId + '"></span>' +
              '</div>' +
              '<input type="hidden" id="ul-size-select-' + productId + '" value="' + (firstVariant.id || '') + '" data-price-raw="' + (firstVariant.price || 0) + '">' +
            '</div>' +
            '<script type="application/json" id="ul-variants-json-' + productId + '">' + variantJson + '<\/script>' +
            '<div class="ul-section" id="ul-qty-section-' + productId + '">' +
              '<div class="ul-section-header"><span class="ul-step-badge" id="ul-step-3-' + productId + '">3</span><span class="ul-section-title">Quantity</span></div>' +
              '<div class="ul-quantity-row"><div class="ul-quantity-control">' +
                '<button type="button" class="ul-qty-btn" id="ul-qty-minus-' + productId + '">−</button>' +
                '<input type="number" class="ul-qty-input" id="ul-qty-input-' + productId + '" value="1" min="1" max="999">' +
                '<button type="button" class="ul-qty-btn" id="ul-qty-plus-' + productId + '">+</button>' +
              '</div><div class="ul-bulk-hint" id="ul-bulk-hint-' + productId + '" style="display:none;"><span>Bulk discount!</span></div></div>' +
            '</div>' +
            '<div class="ul-section" id="ul-questions-section-' + productId + '" style="display:none;">' +
              '<div class="ul-section-header"><span class="ul-step-badge" id="ul-step-4-' + productId + '">4</span><span class="ul-section-title">Additional Options</span></div>' +
              '<div class="ul-questions-container" id="ul-questions-' + productId + '"></div>' +
            '</div>' +
            '<div class="ul-divider"></div>' +
            '<div class="ul-price-summary" id="ul-price-summary-' + productId + '">' +
              '<div class="ul-price-row"><span class="ul-price-label">Size (<span id="ul-selected-size-' + productId + '">-</span>)</span><span class="ul-price-value" id="ul-unit-price-' + productId + '">$0.00</span></div>' +
              '<div class="ul-price-row"><span class="ul-price-label">Quantity</span><span class="ul-price-value">× <span id="ul-qty-display-' + productId + '">1</span></span></div>' +
              '<div class="ul-price-row ul-price-total"><span class="ul-price-label">Total</span><span class="ul-price-value ul-price-total" id="ul-total-price-' + productId + '">$0.00</span></div>' +
            '</div>' +
            '<div class="ul-buttons-stack">' +
              '<button type="button" class="ul-btn ul-btn-secondary" id="ul-tshirt-btn-' + productId + '" style="display:none;" disabled><span>👕</span><span class="ul-btn-text">I want this on a T-Shirt too!</span></button>' +
              '<button type="button" class="ul-btn ul-btn-primary" id="ul-add-cart-' + productId + '" disabled>' +
                '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>' +
                '<span class="ul-btn-text">Add to Cart</span><span class="ul-btn-price" id="ul-btn-price-' + productId + '"></span>' +
              '</button>' +
            '</div>' +
          '</div>' +
          '<input type="hidden" id="ul-upload-id-' + productId + '" value="">' +
          '<input type="hidden" id="ul-upload-url-' + productId + '" value="">' +
          '<input type="hidden" id="ul-thumbnail-url-' + productId + '" value="">' +
        '</div>';

        // Insert container into modal body (not document.body)
        if (modalBody) {
          modalBody.innerHTML = containerHtml;
        } else {
          document.body.insertAdjacentHTML('beforeend', containerHtml);
        }

        // Init ULDTFUploader
        window.ULDTFUploader.init(productId);

        // Open the modal
        var studioModal = document.getElementById('ul-studio-modal');
        var modalTitle = document.getElementById('ul-studio-modal-title');
        if (studioModal) {
          studioModal.classList.add('active');
          document.body.style.overflow = 'hidden';
          if (modalTitle) modalTitle.textContent = productTitle || 'Upload Your Design';
        }

        // Close handlers
        function closeStudioModal() {
          if (studioModal) {
            studioModal.classList.remove('active');
            document.body.style.overflow = '';
          }
        }
        var closeBtn = document.getElementById('ul-studio-modal-close');
        var backdrop = document.getElementById('ul-studio-backdrop');
        if (closeBtn) closeBtn.onclick = closeStudioModal;
        if (backdrop) backdrop.onclick = closeStudioModal;

      } else {
        // Fallback: redirect to product page
        window.location.href = '/products/' + productHandle;
      }
      return;
    }


    /* ─── Mode: dtf_by_size ─── */
    if (mode === 'dtf_by_size') {
      var uploadRoot = document.getElementById('dtf-upload-root');
      if (!uploadRoot) return;

      uploadRoot.setAttribute('data-product-id', productId);
      uploadRoot.setAttribute('data-product-title', productTitle || '');
      uploadRoot.removeAttribute('data-initialized');

      // Product-specific metafields
      if (productData && productData.metafields) {
        uploadRoot.setAttribute('data-max-width', String(productData.metafields.max_width || 22));
        uploadRoot.setAttribute('data-max-height', String(productData.metafields.max_height || 36));
        if (productData.metafields.tiers) {
          uploadRoot.setAttribute('data-tiers', JSON.stringify(productData.metafields.tiers));
        }
      }

      // Destroy existing instance
      if (window.dtfBlock) {
        window.dtfBlock.files = [];
        window.dtfBlock.activeFileIndex = -1;
        window.dtfBlock.state = 'IDLE';
        window.dtfBlock = null;
      }

      // Re-init DtfUploadBlock
      var config = {
        productId: productId,
        productTitle: productTitle || '',
        shopDomain: SHOP_DOMAIN,
        apiBase: API_BASE,
        maxWidth: parseFloat(uploadRoot.getAttribute('data-max-width')) || 22,
        maxHeight: parseFloat(uploadRoot.getAttribute('data-max-height')) || 36,
        minWidth: parseFloat(uploadRoot.getAttribute('data-min-width')) || 1,
        minHeight: parseFloat(uploadRoot.getAttribute('data-min-height')) || 1,
        maxFileMb: parseInt(uploadRoot.getAttribute('data-max-file-mb'), 10) || 500,
        formats: uploadRoot.getAttribute('data-formats'),
        tiers: uploadRoot.getAttribute('data-tiers'),
        currency: uploadRoot.getAttribute('data-currency') || 'USD',
        enableFitcheck: uploadRoot.getAttribute('data-enable-fitcheck') !== 'false'
      };

      if (typeof window.DtfUploadBlock !== 'undefined') {
        window.dtfBlock = new window.DtfUploadBlock(config);
        window.dtfBlock.fetchConfigFallback();
        if (window.dtfBlock.fileInput) {
          window.dtfBlock.fileInput.click();
        }
      }
      return;
    }


    /* ─── Mode: auto_sheet ─── */
    if (mode === 'auto_sheet') {
      // Auto Sheet Calculator
      if (typeof window.ULAutoSheet !== 'undefined') {
        // Create a temporary file input and trigger it
        var fileInput = document.createElement('input');
        fileInput.type = 'file';
        fileInput.accept = '.png,.jpg,.jpeg,.webp,.tiff,.tif,.psd,.pdf,.ai,.eps';
        fileInput.style.display = 'none';
        document.body.appendChild(fileInput);

        fileInput.addEventListener('change', function() {
          if (!fileInput.files || !fileInput.files[0]) return;

          var variants = productData ? productData.variants : [];
          window.ULAutoSheet.openModal({
            file: fileInput.files[0],
            variants: variants,
            productId: productId,
            shopDomain: SHOP_DOMAIN,
            quantity: 1,
            onSelect: function(result) {
              if (result && result.variantId) {
                // Add to cart directly
                fetch('/cart/add.js', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({
                    id: result.variantId,
                    quantity: result.sheetsNeeded || 1
                  })
                }).then(function() {
                  window.location.href = '/cart';
                });
              }
            }
          });

          document.body.removeChild(fileInput);
        });

        fileInput.click();
      } else {
        // Fallback: redirect to product page
        window.location.href = '/products/' + productHandle;
      }
      return;
    }
  }

  // Init
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initListing);
  } else {
    setTimeout(initListing, 200);
  }
})();
</script>


