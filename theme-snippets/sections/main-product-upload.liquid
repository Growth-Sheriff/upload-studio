    var state = {
      uploadId: '',
      originalUrl: '',
      thumbnailUrl: '',
      fileName: '',
      widthPx: 0,
      heightPx: 0,
      trimmedWidthPx: 0,
      trimmedHeightPx: 0,
      trimmedOffsetXPx: 0,
      trimmedOffsetYPx: 0,
      embeddedDpi: 0,
      effectiveDpi: 0,
