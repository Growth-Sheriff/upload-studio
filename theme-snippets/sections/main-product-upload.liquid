<!-- layout/theme.liquid CSS/Tailwind source -->
<script src="https://cdn.tailwindcss.com"></script>
<script>
  tailwind.config = {
    theme: {
      extend: {
        colors: {
          amazon: {
            dark: '{{ settings.color_secondary | default: "#131921" }}',
            light: '{{ settings.color_secondary | default: "#232f3e" }}',
            orange: '{{ settings.color_primary | default: "#ff9900" }}',
            yellow: '{{ settings.color_primary | default: "#febd69" }}',
            link: '{{ settings.color_link | default: "#007185" }}',
            'link-hover': '{{ settings.color_link | default: "#c45500" }}',
            price: '{{ settings.color_price | default: "#B12704" }}',
            success: '{{ settings.color_success | default: "#007600" }}',
            error: '{{ settings.color_error | default: "#cc0c39" }}',
            warning: '{{ settings.color_warning | default: "#e47911" }}',
            border: '{{ settings.color_border | default: "#d5d9d9" }}'
          }
        },
        fontFamily: {
          amazon: ['{{ settings.font_body.family | default: "Arial" }}', 'sans-serif'],
          heading: ['{{ settings.font_heading.family | default: "Arial" }}', 'sans-serif']
        },
        maxWidth: {
          '2k': '2540px'
        },
        borderRadius: {
          'theme': '{{ settings.border_radius | default: 4 }}px'
        }
      }
    }
  }
</script>

{%- assign body_font = settings.font_body -%}
{%- assign heading_font = settings.font_heading -%}
<style>
  {{ body_font | font_face: font_display: 'swap' }}
  {{ heading_font | font_face: font_display: 'swap' }}
  #{{ section_dom_id }} {
    font-family: {{ body_font.family | default: "Arial" }}, sans-serif;
    font-size: {{ settings.font_size_base | default: 14 }}px;
    color: {{ settings.color_text | default: "#0f1111" }};
  }
  #{{ section_dom_id }} h1, #{{ section_dom_id }} h2, #{{ section_dom_id }} h3, #{{ section_dom_id }} h4, #{{ section_dom_id }} h5, #{{ section_dom_id }} h6 {
    font-family: {{ heading_font.family | default: "Arial" }}, sans-serif;
  }
  #{{ section_dom_id }} .hidden {
    display: none;
  }
  #{{ section_dom_id }} .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  #{{ section_dom_id }} .ul-main-variant-row.bg-green-100 td {
    background: #dcfce7;
    color: #14532d;
    font-weight: 700;
  }
  #{{ section_dom_id }} .ul-main-thumb.is-active {
    border-color: {{ settings.color_primary | default: "#ff9900" }};
    box-shadow: 0 0 0 1px {{ settings.color_primary | default: "#ff9900" }};
  }
  #{{ section_dom_id }} .js-accordion-icon {
    transition: transform 0.2s ease;
  }
  #{{ section_dom_id }} .js-accordion-icon.is-open {
    transform: rotate(180deg);
  }
</style>
